import { QuoteRow } from "models.slint";

component RoundedFill inherits Rectangle {
    in property <length> corner-radius;
    in property <color> fill-color;
    background: transparent;

    Rectangle {
        x: root.corner-radius;
        width: parent.width - root.corner-radius * 2;
        height: parent.height;
        background: root.fill-color;
    }

    Rectangle {
        y: root.corner-radius;
        width: parent.width;
        height: parent.height - root.corner-radius * 2;
        background: root.fill-color;
    }

    Path {
        x: 0px;
        y: 0px;
        width: root.corner-radius;
        height: root.corner-radius;
        viewbox-width: 12;
        viewbox-height: 12;
        commands: "M 12 0 L 12 12 L 0 12 C 0 5.37 5.37 0 12 0 Z";
        fill: root.fill-color;
        stroke-width: 0px;
    }

    Path {
        x: parent.width - root.corner-radius;
        y: 0px;
        width: root.corner-radius;
        height: root.corner-radius;
        viewbox-width: 12;
        viewbox-height: 12;
        commands: "M 0 0 L 0 12 L 12 12 C 12 5.37 6.63 0 0 0 Z";
        fill: root.fill-color;
        stroke-width: 0px;
    }

    Path {
        x: 0px;
        y: parent.height - root.corner-radius;
        width: root.corner-radius;
        height: root.corner-radius;
        viewbox-width: 12;
        viewbox-height: 12;
        commands: "M 0 0 L 12 0 L 12 12 C 5.37 12 0 6.63 0 0 Z";
        fill: root.fill-color;
        stroke-width: 0px;
    }

    Path {
        x: parent.width - root.corner-radius;
        y: parent.height - root.corner-radius;
        width: root.corner-radius;
        height: root.corner-radius;
        viewbox-width: 12;
        viewbox-height: 12;
        commands: "M 0 0 L 12 0 C 12 6.63 6.63 12 0 12 L 0 0 Z";
        fill: root.fill-color;
        stroke-width: 0px;
    }
}

export component PriceCardWindow inherits Window {
    in property <string> widget-id;
    in property <[QuoteRow]> quote-rows;
    in property <[image]> quote-icons;
    property <image> empty-quote-icon;
    in property <string> pairs-heading-text;
    in property <string> source-text;
    in property <string> source-name-text;
    in property <string> updated-text;
    in property <string> empty-text;
    in property <bool> pin-to-top;
    in property <bool> layout-locked;
    in property <int> widget-width: 286;
    in property <int> widget-height: 194;
    in property <float> widget-scale: 1.0;
    in property <bool> red-up-enabled;
    in property <bool> compact-mode;
    in property <bool> show-coin-logos: true;
    in property <bool> hide-quote-asset;
    in-out property <bool> card-left-drag-active: false;

    property <length> quote-board-base-width: root.hide-quote-asset
        ? (root.show-coin-logos ? 246px : 224px)
        : (root.show-coin-logos ? 286px : 274px);
    property <int> quote-board-row-count: root.quote-rows.length < 1 ? 1 : (root.quote-rows.length > 20 ? 20 : root.quote-rows.length);
    property <length> quote-board-base-height: root.quote-board-row-count <= 1
        ? 80px
        : (root.quote-board-row-count <= 5
            ? 70px + (root.quote-board-row-count - 1) * 31px
            : 194px + (root.quote-board-row-count - 5) * 26px);
    property <length> shell-width: root.compact-mode ? 236px : root.quote-board-base-width;
    property <length> shell-height: root.compact-mode ? 112px : root.quote-board-base-height;
    property <length> window-padding: 6px;
    property <length> content-width: root.shell-width - root.window-padding * 2;
    property <length> content-height: root.shell-height - root.window-padding * 2;
    property <float> content-scale: root.widget-scale;
    property <length> card-edge-inset: root.light-theme ? 2px : 1px;
    property <length> card-outer-radius: root.light-theme ? 11px : 10px;
    property <length> card-radius: 12px;
    property <length> card-inner-radius: 11px;
    property <length> card-border-width: 1px;
    property <length> card-rim-size: 2px;
    property <length> card-shadow-blur: root.light-theme ? 16px : 0px;
    property <length> card-edge-shadow-blur: root.light-theme ? 8px : 0px;
    property <color> card-shadow-color: root.light-theme ? #0f172a24 : #00000000;
    property <color> card-edge-shadow-color: root.light-theme ? #0f172a18 : #7dd3fc24;
    property <bool> quote-icon-space-visible: root.show-coin-logos;
    property <length> quote-board-row-width: root.s(root.content-width - root.card-edge-inset * 2 - 24px);
    property <length> quote-board-row-start-y: root.s(root.quote-board-row-count <= 1 ? 35px : 41px);
    property <length> quote-board-symbol-x: root.s(root.quote-icon-space-visible ? 25px : 4px);
    property <length> quote-board-symbol-width: root.s(root.hide-quote-asset ? 46px : (root.quote-icon-space-visible ? 80px : 92px));
    property <length> quote-board-price-x: root.quote-board-symbol-x + root.quote-board-symbol-width + root.s(6px);
    property <length> quote-board-change-width: root.s(64px);
    property <length> quote-board-change-x: root.quote-board-row-width - root.quote-board-change-width;
    property <length> quote-board-price-width: root.quote-board-change-x - root.quote-board-price-x - root.s(8px);
    in property <int> content-opacity;
    in property <string> theme-name: "dark";
    property <bool> light-theme: root.theme-name == "light";
    property <color> card-background: root.light-theme ? #f8fbffff : #101c2dff;
    property <color> card-header-background: root.light-theme ? #eaf7ffff : #0d1a2dff;
    property <color> card-border-color: root.light-theme ? #0f172a16 : #d8f4ff0e;
    property <color> card-inner-border-color: root.light-theme ? #0f172a10 : #d8f4ff08;
    property <color> row-background: root.light-theme ? #ffffffb8 : #1722358a;
    property <color> row-divider-color: root.light-theme ? #cbd5e155 : #33415580;
    property <color> gain-pill-background: root.light-theme ? #d1fae5ff : #064e3bcc;
    property <color> loss-pill-background: root.light-theme ? #fee2e2ff : #4c1d2fcc;
    property <color> card-primary-text-color: root.light-theme ? #071426 : #f8fafc;
    property <color> card-source-text-color: root.light-theme ? #0369a1 : #67d8ff;
    property <color> card-updated-text-color: root.light-theme ? #64748b : #9db2ce;
    property <color> gain-color: root.light-theme ? #047857 : #22d76f;
    property <color> loss-color: root.light-theme ? #dc2626 : #ff6b76;
    property <color> lock-button-background: root.light-theme ? #ffffffcc : #12233add;
    property <color> lock-button-hover-background: root.light-theme ? #e0f2feee : #162b46ee;
    property <color> lock-button-border-color: root.light-theme ? #94a3b880 : #7dd3fc66;
    property <color> lock-icon-color: root.light-theme ? #0f172a : #dbeafe;

    callback drag-move(length, length);
    callback toggle-layout-lock();
    function s(value: length) -> length {
        return value * root.content-scale;
    }
    title: root.widget-id;
    width: root.widget-width * 1px;
    height: root.widget-height * 1px;
    icon: @image-url("icon.png");
    no-frame: true;
    always-on-top: root.pin-to-top;
    background: transparent;

    drag_area := TouchArea {
        width: root.widget-width * 1px;
        height: root.widget-height * 1px;
        mouse-cursor: root.layout-locked ? default : (self.pressed ? grabbing : grab);
        pointer-event(event) => {
            if !root.layout-locked && event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                root.card-left-drag-active = true;
            } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                root.card-left-drag-active = false;
            }
        }
        moved => {
            if !root.layout-locked && root.card-left-drag-active {
                root.drag-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
            }
        }
    }

    edge_shadow := Rectangle {
        x: (root.widget-width * 1px - root.s(root.content-width)) / 2 - root.s(root.card-rim-size);
        y: (root.widget-height * 1px - root.s(root.content-height)) / 2 - root.s(root.card-rim-size);
        width: root.s(root.content-width + root.card-rim-size * 2);
        height: root.s(root.content-height + root.card-rim-size * 2);
        border-radius: root.s(root.card-radius + root.card-rim-size);
        background: transparent;
        opacity: root.content-opacity / 100;
        drop-shadow-offset-y: 0px;
        drop-shadow-blur: root.s(root.card-edge-shadow-blur);
        drop-shadow-color: root.card-edge-shadow-color;

        RoundedFill {
            width: parent.width;
            height: parent.height;
            corner-radius: root.s(root.card-radius + root.card-rim-size);
            fill-color: root.card-edge-shadow-color;
        }
    }

    card := Rectangle {
        x: edge_shadow.x + root.s(root.card-rim-size);
        y: edge_shadow.y + root.s(root.card-rim-size);
        width: edge_shadow.width - root.s(root.card-rim-size * 2);
        height: edge_shadow.height - root.s(root.card-rim-size * 2);
        border-radius: root.s(root.card-radius);
        background: transparent;
        border-width: 0px;
        border-color: transparent;
        opacity: root.content-opacity / 100;
        drop-shadow-offset-y: root.s(root.light-theme ? 4px : 0px);
        drop-shadow-blur: root.s(root.card-shadow-blur);
        drop-shadow-color: root.card-shadow-color;
        clip: true;

        RoundedFill {
            width: parent.width;
            height: parent.height;
            corner-radius: root.s(root.card-radius);
            fill-color: root.card-background;
        }

        Rectangle {
            x: root.s(1px);
            y: root.s(1px);
            width: parent.width - root.s(2px);
            height: parent.height - root.s(2px);
            border-radius: root.s(root.card-inner-radius);
            background: transparent;
            border-width: 0px;
            border-color: transparent;
        }

        Rectangle {
            x: root.s(1px);
            y: root.s(31px);
            width: parent.width - root.s(2px);
            height: root.s(1px);
            background: root.row-divider-color;
            visible: !root.compact-mode;
        }

        Text {
            x: root.s(14px);
            y: root.s(9px);
            width: root.s(50px);
            height: root.s(17px);
            text: root.pairs-heading-text == "" ? "Pairs" : root.pairs-heading-text;
            color: root.card-primary-text-color;
            font-size: root.s(13px);
            font-weight: 800;
            visible: !root.compact-mode;
            overflow: elide;
        }

        Text {
            x: root.s(68px);
            y: root.s(10px);
            width: parent.width - root.s(104px);
            height: root.s(15px);
            text: root.source-name-text == "" ? (root.source-text == "" ? "Source" : root.source-text) : root.source-name-text + " · " + root.updated-text;
            color: root.card-source-text-color;
            font-size: root.s(11px);
            font-weight: 700;
            horizontal-alignment: right;
            visible: !root.compact-mode;
            overflow: elide;
        }

        for quote[index] in root.quote-rows : Rectangle {
            x: root.s(root.compact-mode ? 10px : 12px);
            y: root.compact-mode ? root.s(16px) : root.quote-board-row-start-y + root.s(index * 26px);
            width: root.compact-mode ? parent.width - root.s(20px) : root.quote-board-row-width;
            height: root.s(root.compact-mode ? 30px : 25px);
            border-radius: root.s(5px);
            background: !root.compact-mode && Math.mod(index, 2) == 0 ? root.row-background : transparent;
            visible: root.compact-mode ? index == 0 : index < root.quote-board-row-count;

            Rectangle {
                x: 0px;
                y: parent.height - root.s(1px);
                width: parent.width;
                height: root.s(1px);
                background: root.row-divider-color;
                visible: !root.compact-mode && index + 1 < root.quote-board-row-count;
            }

            Image {
                x: root.s(root.compact-mode ? 6px : 0px);
                y: root.s(root.compact-mode ? 6px : 3px);
                width: root.s(root.compact-mode ? 18px : 18px);
                height: root.s(root.compact-mode ? 18px : 18px);
                source: root.quote-icons.length > index ? root.quote-icons[index] : root.empty-quote-icon;
                image-fit: contain;
                visible: root.show-coin-logos && root.quote-icons.length > index;
            }

            Text {
                x: root.compact-mode ? root.s(30px) : root.quote-board-symbol-x;
                y: 0px;
                width: root.compact-mode ? root.s(44px) : root.quote-board-symbol-width;
                height: parent.height;
                text: quote.symbol;
                color: root.card-primary-text-color;
                font-size: root.s(root.compact-mode ? 13px : 12px);
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                x: root.compact-mode ? root.s(78px) : root.quote-board-price-x;
                y: 0px;
                width: root.compact-mode ? root.s(74px) : root.quote-board-price-width;
                height: parent.height;
                text: quote.price;
                color: root.card-primary-text-color;
                font-size: root.s(root.compact-mode ? 14px : 13px);
                font-weight: 800;
                horizontal-alignment: right;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: root.compact-mode ? root.s(156px) : root.quote-board-change-x;
                y: root.s(root.compact-mode ? 4px : 3px);
                width: root.compact-mode ? root.s(56px) : root.quote-board-change-width;
                height: root.s(root.compact-mode ? 22px : 19px);
                border-radius: root.s(5px);
                background: quote.positive
                    ? (root.red-up-enabled ? root.loss-pill-background : root.gain-pill-background)
                    : (root.red-up-enabled ? root.gain-pill-background : root.loss-pill-background);
                visible: !root.compact-mode;
            }

            Text {
                x: root.compact-mode ? root.s(164px) : root.quote-board-change-x + root.s(4px);
                y: 0px;
                width: root.compact-mode ? root.s(48px) : root.quote-board-change-width - root.s(8px);
                height: parent.height;
                text: quote.change;
                color: quote.positive
                    ? (root.red-up-enabled ? root.loss-color : root.gain-color)
                    : (root.red-up-enabled ? root.gain-color : root.loss-color);
                font-size: root.s(root.compact-mode ? 13px : 12px);
                font-weight: 800;
                horizontal-alignment: right;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Text {
            x: root.s(14px);
            y: root.s(root.compact-mode ? 48px : 42px);
            width: parent.width - root.s(28px);
            text: root.empty-text;
            color: root.card-updated-text-color;
            font-size: root.s(12px);
            horizontal-alignment: center;
            visible: root.quote-rows.length == 0;
            overflow: elide;
        }

        Text {
            x: root.s(14px);
            y: parent.height - root.s(root.compact-mode ? 36px : 24px);
            width: parent.width / 2 - root.s(18px);
            text: root.source-text;
            color: root.card-source-text-color;
            font-size: root.s(11px);
            horizontal-alignment: left;
            visible: root.compact-mode;
            overflow: elide;
        }

        Text {
            x: parent.width / 2;
            y: parent.height - root.s(root.compact-mode ? 36px : 24px);
            width: parent.width / 2 - root.s(14px);
            text: root.updated-text;
            color: root.card-updated-text-color;
            font-size: root.s(11px);
            horizontal-alignment: right;
            visible: root.compact-mode;
            overflow: elide;
        }

        lock_button := Rectangle {
            x: parent.width - root.s(root.compact-mode ? 40px : 31px);
            y: root.s(6px);
            width: root.s(root.compact-mode ? 32px : 24px);
            height: root.s(root.compact-mode ? 32px : 24px);
            border-radius: root.s(root.compact-mode ? 8px : 6px);
            background: root.layout-locked ? root.lock-button-hover-background : (lock_button_hit_area.has-hover ? root.lock-button-background : transparent);
            border-width: root.s(1px);
            border-color: root.layout-locked || lock_button_hit_area.has-hover ? root.lock-button-border-color : transparent;
            visible: drag_area.has-hover || lock_button_hit_area.has-hover;

            Path {
                x: root.s(root.compact-mode ? 7px : 4px);
                y: root.s(root.compact-mode ? 6px : 3px);
                width: root.s(root.compact-mode ? 18px : 16px);
                height: root.s(root.compact-mode ? 20px : 18px);
                viewbox-width: 24;
                viewbox-height: 24;
                commands: "M 8 4 L 16 4 L 16 6 L 15 6 L 15 12 L 18 14 L 18 16 L 13 16 L 13 21 L 11 21 L 11 16 L 6 16 L 6 14 L 9 12 L 9 6 L 8 6 Z";
                fill: root.layout-locked ? root.lock-icon-color : transparent;
                stroke: root.lock-icon-color;
                stroke-width: root.s(2px);
                stroke-line-cap: round;
                stroke-line-join: round;
            }

        }
    }

    lock_button_hit_area := TouchArea {
        x: card.x + card.width - root.s(root.compact-mode ? 40px : 31px);
        y: card.y + root.s(6px);
        width: root.s(root.compact-mode ? 32px : 24px);
        height: root.s(root.compact-mode ? 32px : 24px);
        mouse-cursor: pointer;
        clicked => { root.toggle-layout-lock(); }
    }
}
