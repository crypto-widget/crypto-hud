                    font-weight: 500;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                }
            }
        }


        plugin_market_tab := Rectangle {
            x: 179px;
            y: 53px;
            width: parent.width - 179px;
            height: parent.height - 53px;
            background: root.settings-content-background;
            visible: root.settings-tab-index == 1;

            PanelTitle {
                x: 17px;
                y: 16px;
                width: 459px;
                title: root.tab-plugin-market-text;
                subtitle: root.plugin-market-description-text;
                title-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
            }

            plugin_market_list := ListView {
                x: 17px;
                y: 66px;
                width: plugin_market_tab.width - 34px;
                height: parent.height - 83px;

                for plugin[index] in root.plugin-market-items : Rectangle {
                    width: plugin_market_list.width;
                    height: 106px;
                    border-radius: 6px;
                    background: root.settings-surface-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    Rectangle {
                        x: 16px;
                        y: 17px;
                        width: 123px;
                        height: 72px;
                        border-radius: 6px;
                        background: root.settings-preview-card-background;
                        border-width: 1px;
                        border-color: root.settings-preview-border-color;
                        visible: plugin.preview_image_count <= 0 && plugin.preview_kind == 0;

                        Rectangle {
                            x: 1px;
                            y: 1px;
                            width: parent.width - 1px;
                            height: 16px;
                            border-radius: 5px;
                            background: root.settings-preview-header-background;
                        }

                        Text {
                            x: 9px;
                            y: 6px;
                            text: plugin.builtin ? "BTC" : "SLINT";
                            color: root.settings-preview-primary-color;
