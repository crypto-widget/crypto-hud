    in property <string> widget-library-text;
    in property <string> my-widgets-text;
    in property <string> selected-widget-text;
    in property <string> selected-widget-description-text;
    in property <string> widget-name-text;
    in property <string> lock-position-help-text;
    in property <string> widget-scale-help-text;
    in property <string> opacity-help-text;
    in property <string> widget-show-coin-logos-text;
    in property <string> widget-show-coin-logos-help-text;
    in property <string> widget-hide-quote-asset-text;
    in property <string> widget-hide-quote-asset-help-text;
    in property <string> widget-theme-text;
    in property <string> widget-theme-help-text;
    in property <string> widget-topmost-text;
    in property <string> widget-topmost-help-text;
    in property <string> advanced-options-text;
    in property <string> reset-widget-positions-text;
    in property <string> hide-all-widgets-text;
    in property <string> reset-text;
    in property <string> delete-widget-text;
    in property <string> widget-visible-text;
    in property <string> widget-hidden-text;
    in property <string> preview-text;
    in property <string> preview-pairs-text;
    in property <string> preview-updated-text;
    in property <string> preview-source-ok-text;
    in property <string> app-settings-text;
    in property <string> add-widget-text;
    in property <string> apply-widget-text;
    in property <string> no-widgets-text;
    in property <string> plugin-market-description-text;
    in property <string> my-widgets-description-text;
    in property <string> market-settings-description-text;
    in property <string> appearance-settings-description-text;
    in property <string> system-settings-description-text;
    in property <string> quote-board-title-text;
    in property <string> quote-board-description-text;
    in property <string> mini-ticker-title-text;
    in property <string> mini-ticker-description-text;
    in property <string> market-settings-text;
    in property <string> appearance-settings-text;
    in property <string> system-settings-text;
    in property <string> settings-path-label-text;
    in property <string> close-text;
    in property <color> settings-background: #fcfcfa;
    in property <color> settings-heading-color: #15181b;
    in property <color> settings-label-color: #22272c;
    in property <color> settings-muted-color: #70747a;
    in property <color> settings-status-color: #087f78;
    in property <color> settings-header-background: #fbfbfa;
    in property <color> settings-nav-background: #fbfbfa;
    in property <color> settings-content-background: #fbfbfa;
    in property <color> settings-surface-background: #ffffff;
    in property <color> settings-selected-background: #f0f7f5;
    in property <color> settings-border-color: #e7e7e8;
    in property <color> settings-divider-color: #e8e8e8;
    in property <color> settings-accent-color: #0a7f78;
    in property <color> settings-accent-text-color: #f8fafc;
    in property <color> settings-track-color: #3d4a44;
    in property <color> settings-knob-color: #f8fafc;
    in property <color> settings-window-edge-color: #a9a9aa;
    in property <color> settings-sidebar-top-border-color: #eeeeed;
    in property <color> settings-nav-selected-background: #ebf1ef;
    in property <color> settings-nav-accent-color: #0a716e;
    in property <bool> settings-dark-mode: false;
    in property <color> settings-preview-card-background: #111827dd;
    in property <color> settings-preview-header-background: #0f172acc;
    in property <color> settings-preview-border-color: #475569;
    in property <color> settings-preview-primary-color: #f8fafc;
    in property <color> settings-preview-source-color: #93c5fd;
    in property <color> settings-preview-updated-color: #94a3b8;
    property <bool> can-add-widget-symbol: root.has-widgets && root.widget-symbol-values.length < root.widget-symbol-max;
    property <bool> can-remove-widget-symbol: root.has-widgets && root.widget-symbol-values.length > root.widget-symbol-min;
    property <bool> can-add-default-symbol: root.default-symbol-values.length < root.default-symbol-max;
    property <bool> can-remove-default-symbol: root.default-symbol-values.length > root.default-symbol-min;
    property <bool> can-confirm-symbol-picker: root.symbol-picker-open && root.symbol-picker-candidate-options.length > 0;

    callback apply-settings(bool, bool, bool, bool, bool, bool, bool, int, int, int, bool, int, int, int, bool, bool);
    callback apply-network-settings(bool, string);
    callback apply-alert-settings(bool, string, int, string);
    callback clear-alert-settings();
    callback refresh-symbol-picker-candidates();
    callback open-widget-symbol-picker();
    callback open-widget-symbol-replace-picker(int);
    callback open-default-symbol-picker();
    callback open-default-symbol-replace-picker(int);
    callback close-symbol-picker();
    callback confirm-symbol-picker(int, int);
    callback remove-default-symbol(int);
    callback remove-widget-symbol(int, int);
    callback select-widget(int);
    callback add-widget(int);
    callback apply-widget-settings(int, string, bool, bool, int, int, int, bool, bool);
    callback apply-widget-scale(int, int);
    callback toggle-widget-visibility(int);
    callback reset-widget-positions();
    callback hide-all-widgets();
    callback widget-list-press(int);
    callback widget-list-drag(length);
    callback widget-list-release();
    callback delete-widget(int);
    callback minimize-settings();
    callback close-settings();
    callback drag-settings(length, length);
    callback open-about-link();
    callback clear-icon-cache();
    callback open-custom-components-folder();

    width: 1120px;
    height: 720px;
    title: root.window-title-text;
    no-frame: true;
    icon: @image-url("icon.png");
    default-font-family: "Noto Sans SC";
    background: root.settings-background;

    init => {
        Palette.color-scheme = root.settings-dark-mode ? ColorScheme.dark : ColorScheme.light;
    }

    changed settings-dark-mode => {
        Palette.color-scheme = root.settings-dark-mode ? ColorScheme.dark : ColorScheme.light;
    }

    function apply-current-settings() {
        root.apply-settings(
            root.red-up-enabled,
            root.market-binance-enabled,
            root.market-coinbase-enabled,
            root.market-okx-enabled,
            root.market-hyperliquid-enabled,
            root.auto-start-enabled,
            root.show-main-window-on-startup,
            root.shortcut-index,
            root.theme-index,
            root.language-index,
            root.default-widgets-always-on-top,
            root.default-opacity-percent,
            root.default-widget-scale-percent,
            root.refresh-interval-seconds,
            root.tray-icon-enabled,
            root.tray-hover-display-enabled
        );
    }

    function apply-current-widget-settings() {
        if root.has-widgets && root.selected-widget-index >= 0 {
            root.apply-widget-settings(
                root.selected-widget-index,
                root.widget-name-input-text,
                root.widgets-always-on-top,
                root.widget-layout-locked,
                root.opacity-percent,
                root.widget-scale-percent,
                root.widget-theme-index,
                root.widget-show-coin-logos,
                root.widget-hide-quote-asset
            );
        }
    }

    function apply-current-network-settings() {
        root.apply-network-settings(
            root.network-proxy-enabled,
            root.network-proxy-url-input-text
        );
    }

    function apply-current-alert-settings() {
        root.apply-alert-settings(
            root.alert-enabled,
            root.alert-symbol-options[root.alert-symbol-index],
            root.alert-condition-index,
            root.alert-threshold-input-text
        );
    }

    panel := Rectangle {
        x: (root.width - root.settings-design-width * root.settings-window-scale) / 2;
        y: (root.height - root.settings-design-height * root.settings-window-scale) / 2;
        width: root.settings-design-width;
        height: root.settings-design-height;
        transform-origin: { x: 0px, y: 0px };
        transform-scale-x: root.settings-window-scale;
        transform-scale-y: root.settings-window-scale;
        background: root.settings-background;

        titlebar := Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 53px;
            background: root.settings-background;

            TouchArea {
                width: parent.width - 92px;
                height: parent.height;
                mouse-cursor: self.pressed ? grabbing : grab;
                moved => {
                    root.drag-settings(
                        (self.mouse-x - self.pressed-x) * root.settings-window-scale,
                        (self.mouse-y - self.pressed-y) * root.settings-window-scale
                    );
                }
            }

            Text {
                x: 49px;
                y: 16px;
                width: 258px;
                text: root.window-title-text;
                color: root.settings-heading-color;
                font-size: 16px;
                font-weight: 400;
                overflow: elide;
            }

            Image {
                x: 19px;
                y: 17px;
                width: 19px;
                height: 19px;
                source: @image-url("icon-small.png");
                image-fit: contain;
            }

            minimize_button := Rectangle {
                x: parent.width - 95px;
                y: 14px;
                width: 32px;
                height: 26px;
                border-radius: 4px;
                background: minimize_touch.has-hover ? root.settings-selected-background : transparent;
                border-width: 1px;
                border-color: minimize_touch.has-hover ? root.settings-border-color : transparent;

                Text {
                    y: -6px;
                    width: parent.width;
                    text: "-";
                    color: root.settings-heading-color;
                    font-size: 31px;
                    font-weight: 400;
                    horizontal-alignment: center;
                }

                minimize_touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { root.minimize-settings(); }
                }
            }

            close_button := Rectangle {
                x: parent.width - 47px;
                y: 14px;
                width: 32px;
                height: 26px;
                border-radius: 4px;
                background: close_touch.has-hover ? root.settings-selected-background : transparent;
                border-width: 1px;
                border-color: close_touch.has-hover ? root.settings-border-color : transparent;

                Text {
                    y: 0px;
                    width: parent.width;
                    text: "X";
                    color: root.settings-heading-color;
                    font-size: 19px;
                    font-weight: 500;
                    horizontal-alignment: center;
                }

                close_touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { root.close-settings(); }
                }
            }

        }

        sidebar := Rectangle {
            x: 0px;
            y: 53px;
            width: 179px;
            height: parent.height - 53px;
            background: root.settings-nav-background;
            border-width: 0px;

            Rectangle {
                x: parent.width - 1px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: root.settings-border-color;
            }

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 1px;
                background: root.settings-sidebar-top-border-color;
            }

            SettingsNavItem {
                x: 6px;
                y: 19px;
                text: root.tab-widgets-text;
                icon-kind: 0;
                selected: root.settings-tab-index == 0;
                selected-background: root.settings-nav-selected-background;
                hover-background: root.settings-surface-background;
                accent-color: root.settings-nav-accent-color;
                label-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                clicked => { root.settings-tab-index = 0; }
            }

            SettingsNavItem {
                x: 6px;
                y: 60px;
                text: root.tab-plugin-market-text;
                icon-kind: 1;
                selected: root.settings-tab-index == 1;
                selected-background: root.settings-nav-selected-background;
                hover-background: root.settings-surface-background;
                accent-color: root.settings-nav-accent-color;
                label-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                clicked => { root.settings-tab-index = 1; }
            }

            SettingsNavItem {
                x: 6px;
                y: 102px;
                text: root.tab-market-data-text;
                icon-kind: 2;
                selected: root.settings-tab-index == 2;
                selected-background: root.settings-nav-selected-background;
                hover-background: root.settings-surface-background;
                accent-color: root.settings-nav-accent-color;
                label-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                clicked => { root.settings-tab-index = 2; }
            }

            SettingsNavItem {
                x: 6px;
                y: 143px;
                text: root.tab-appearance-text;
                icon-kind: 3;
                selected: root.settings-tab-index == 3;
                selected-background: root.settings-nav-selected-background;
                hover-background: root.settings-surface-background;
                accent-color: root.settings-nav-accent-color;
                label-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                clicked => { root.settings-tab-index = 3; }
            }

            SettingsNavItem {
                x: 6px;
                y: 185px;
                text: root.tab-system-text;
                icon-kind: 4;
                selected: root.settings-tab-index == 4;
                selected-background: root.settings-nav-selected-background;
                hover-background: root.settings-surface-background;
                accent-color: root.settings-nav-accent-color;
                label-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                clicked => { root.settings-tab-index = 4; }
            }

            Rectangle {
                x: 6px;
                y: parent.height - 65px;
                width: parent.width - 17px;
                height: 1px;
                background: root.settings-divider-color;
            }

            GithubProjectSignature {
                x: 6px;
                y: parent.height - 51px;
                width: parent.width - 17px;
                height: 36px;
                project-name: "crypto-hud";
                version-text: root.app-version-value-text;
                status-text: root.status-text;
                label-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                accent-color: root.settings-accent-color;
                clicked => { root.open-about-link(); }
            }

        }

        widget_tab := Rectangle {
            x: 179px;
            y: 53px;
            width: parent.width - 179px;
            height: parent.height - 53px;
            background: root.settings-content-background;
            visible: root.settings-tab-index == 0;

            PanelTitle {
                x: 17px;
                y: 16px;
                width: 459px;
                title: root.my-widgets-text;
                subtitle: root.my-widgets-description-text;
                title-color: root.settings-heading-color;
                muted-color: root.settings-muted-color;
                visible: false;
            }

            Rectangle {
                x: 15px;
                y: 0px;
                width: 401px;
                height: 600px;
                border-radius: 4px;
                background: root.settings-surface-background;
                border-width: 1px;
                border-color: root.settings-border-color;

                Text {
                    x: 17px;
                    y: 21px;
                    width: parent.width - 140px;
                    text: root.my-widgets-text;
                    color: root.settings-heading-color;
                    font-size: 16px;
                    font-weight: 500;
                    overflow: elide;
                }

                Rectangle {
                    x: 0px;
                    y: 56px;
                    width: parent.width;
                    height: 1px;
                    background: root.settings-divider-color;
                }

                widget_list := ListView {
                    x: 0px;
                    y: 56px;
                    width: parent.width;
                    height: parent.height - 38px;

                    for widget_label[index] in root.widget-list-options : Rectangle {
                        width: 401px;
                        height: 66px;
                        border-radius: 4px;
                        background: root.selected-widget-index == index ? root.settings-selected-background : list_row_touch.has-hover ? root.settings-content-background : transparent;

                        WidgetListPreviewCarousel {
                            x: 58px;
                            y: 10px;
                            width: 64px;
                            height: 46px;
                            image-count: root.widget-preview-image-counts[index];
                            preview-image-a: root.widget-preview-image-1-options[index];
                            preview-image-b: root.widget-preview-image-2-options[index];
                            preview-image-c: root.widget-preview-image-3-options[index];
                            preview-image-d: root.widget-preview-image-4-options[index];
                            preview-image-e: root.widget-preview-image-5-options[index];
                            frame-index: root.widget-preview-frame-indices[index];
                            surface-color: root.settings-surface-background;
                            preview-border-color: root.settings-border-color;
                            muted-color: root.settings-muted-color;
                            accent-color: root.settings-accent-color;
                            fallback-background: root.settings-content-background;
                            fallback-text-color: root.settings-muted-color;
                        }

                        Rectangle {
                            x: 14px;
                            y: 24px;
                            width: 34px;
                            height: 19px;
                            border-radius: 9px;
                            background: root.widget-visible-options[index] ? root.settings-accent-color : root.settings-track-color;

                            Rectangle {
                                x: root.widget-visible-options[index] ? 17px : 2px;
                                y: 2px;
                                width: 13px;
                                height: 13px;
                                border-radius: 6px;
                                background: root.settings-knob-color;
                            }

                            TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => {
                                    root.widget-action-menu-index = -1;
                                    root.toggle-widget-visibility(index);
                                }
                            }
                        }

                        Text {
                            x: 136px;
                            y: 19px;
                            width: 211px;
                            height: 13px;
                            text: widget_label;
                            color: root.widget-visible-options[index] ? root.settings-label-color : root.settings-muted-color;
                            font-size: 11px;
                            font-weight: 500;
                            overflow: elide;
                        }

                        Text {
                            x: 136px;
                            y: 40px;
                            width: 211px;
                            height: 11px;
                            text: root.widget-list-detail-options[index];
                            color: root.settings-muted-color;
                            font-size: 9px;
                            font-weight: 500;
                            overflow: elide;
                        }

                        more_widget_button := Rectangle {
                            x: 361px;
                            y: 19px;
                            width: 27px;
                            height: 27px;
                            border-radius: 4px;
                            background: more_widget_touch.has-hover || root.widget-action-menu-index == index ? root.settings-content-background : root.settings-surface-background;
                            border-width: 1px;
                            border-color: root.settings-border-color;

                            Rectangle { x: 12px; y: 6px; width: 3px; height: 3px; border-radius: 1px; background: root.settings-label-color; }
                            Rectangle { x: 12px; y: 12px; width: 3px; height: 3px; border-radius: 1px; background: root.settings-label-color; }
                            Rectangle { x: 12px; y: 18px; width: 3px; height: 3px; border-radius: 1px; background: root.settings-label-color; }

                            more_widget_touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => {
                                    root.selected-widget-index = index;
                                    root.select-widget(index);
                                    if root.widget-action-menu-index == index {
                                        root.widget-action-menu-index = -1;
                                    } else {
                                        root.widget-action-menu-index = index;
                                    }
                                }
                            }
                        }

                        list_row_touch := TouchArea {
                            x: 130px;
                            y: 0px;
                            width: 222px;
                            height: 60px;
                            mouse-cursor: pointer;
                            clicked => {
                                root.widget-action-menu-index = -1;
                                root.selected-widget-index = index;
                                root.select-widget(index);
                            }
                        }

                        Rectangle {
                            x: 0px;
                            y: parent.height - 1px;
                            width: parent.width;
                            height: 1px;
                            background: root.settings-divider-color;
                        }
                    }
                }

                action_menu := Rectangle {
                    property <length> row-y: widget_list.y + root.widget-action-menu-index * 66px + widget_list.viewport-y;
                    property <length> below-y: self.row-y + 50px;
                    property <length> above-y: self.row-y - 33px;
                    x: 269px;
                    y: self.below-y + self.height <= parent.height ? self.below-y : max(widget_list.y + 1px, self.above-y);
                    width: 97px;
                    height: 30px;
                    border-radius: 4px;
                    background: root.settings-surface-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;
                    visible: root.widget-action-menu-index >= 0 && root.widget-action-menu-index < root.widget-list-options.length && self.row-y + 66px > widget_list.y && self.row-y < widget_list.y + widget_list.height;

                    Rectangle {
                        x: 4px;
                        y: 4px;
                        width: parent.width - 9px;
                        height: 21px;
                        border-radius: 4px;
                        background: remove_widget_menu_touch.has-hover ? #ef444422 : transparent;

                        Text {
                            x: 9px;
                            y: 5px;
                            width: parent.width - 17px;
                            text: root.delete-widget-text;
                            color: #ef4444;
                            font-size: 9px;
                            font-weight: 800;
                            overflow: elide;
                        }

                        remove_widget_menu_touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => {
                                root.delete-widget(root.widget-action-menu-index);
                                root.widget-action-menu-index = -1;
                            }
                        }
                    }
                }

                Text {
                    x: 17px;
                    y: 222px;
                    width: parent.width - 34px;
                    height: 17px;
                    text: root.no-widgets-text;
                    color: root.settings-muted-color;
                    font-size: 10px;
                    font-weight: 500;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                    visible: !root.has-widgets;
                }
            }

            selected_widget_panel := Rectangle {
                x: 429px;
                y: 0px;
                width: 503px;
                height: parent.height;
                border-radius: 4px;
                background: root.settings-surface-background;
                border-width: 1px;
                border-color: root.settings-border-color;
                visible: root.has-widgets;

                ScrollView {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: selected_widget_panel.width - root.widget-settings-scrollbar-gutter;
                    viewport-height: root.selected-widget-content-height;

                    Rectangle {
                        x: 0px;
                        y: 0px;
                        width: selected_widget_panel.width - root.widget-settings-scrollbar-gutter;
                        height: root.selected-widget-content-height;

                Text {
                    x: 17px;
                    y: 21px;
                    width: parent.width - 34px;
                    height: 21px;
                    text: root.selected-widget-text + " " + root.widget-name-input-text;
                    color: root.settings-heading-color;
                    font-size: 16px;
                    font-weight: 500;
                    overflow: elide;
                }

                Text {
                    x: 17px;
                    y: 47px;
                    width: parent.width - 34px;
                    height: 14px;
                    text: root.selected-widget-description-text;
                    color: root.settings-muted-color;
                    font-size: 10px;
                    overflow: elide;
                }

                Rectangle {
                    x: 0px;
                    y: 133px;
                    width: parent.width;
                    height: 1px;
                    background: root.settings-divider-color;
                }

                Rectangle {
                    x: 0px;
                    y: 205px;
                    width: parent.width;
                    height: 1px;
                    background: root.settings-divider-color;
                }

                SettingLabel {
                    x: 17px;
                    y: 95px;
                    width: 95px;
                    label: root.widget-name-text;
                    help: "";
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                LineEdit {
                    x: 143px;
                    y: 80px;
                    width: parent.width - 161px;
                    height: 39px;
                    text <=> root.widget-name-input-text;
                    edited(_) => { root.apply-current-widget-settings(); }
                }

                SettingLabel {
                    x: 17px;
                    y: 155px;
                    width: 186px;
                    label: root.always-on-top-text;
                    help: root.lock-position-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                SettingSwitch {
                    x: parent.width - 54px;
                    y: 161px;
                    checked <=> root.widget-layout-locked;
                    accent-color: root.settings-accent-color;
                    track-color: root.settings-track-color;
                    knob-color: root.settings-knob-color;
                    toggled => { root.apply-current-widget-settings(); }
                }

                TouchArea {
                    x: 17px;
                    y: 139px;
                    width: parent.width - 89px;
                    height: 59px;
                    clicked => {
                        root.widget-layout-locked = !root.widget-layout-locked;
                        root.apply-current-widget-settings();
                    }
                }

                SettingLabel {
                    x: 17px;
                    y: 215px;
                    width: 186px;
                    label: root.widget-topmost-text;
                    help: root.widget-topmost-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                SettingSwitch {
                    x: parent.width - 54px;
                    y: 222px;
                    checked <=> root.widgets-always-on-top;
                    accent-color: root.settings-accent-color;
                    track-color: root.settings-track-color;
                    knob-color: root.settings-knob-color;
                    toggled => { root.apply-current-widget-settings(); }
                }

                TouchArea {
                    x: 17px;
                    y: 206px;
                    width: parent.width - 89px;
                    height: 46px;
                    clicked => {
                        root.widgets-always-on-top = !root.widgets-always-on-top;
                        root.apply-current-widget-settings();
                    }
                }

                Text {
                    x: 17px;
                    y: 285px;
                    width: 50px;
                    height: 14px;
                    text: root.symbols-text;
                    color: root.settings-heading-color;
                    font-size: 11px;
                    font-weight: 500;
                    overflow: elide;
                }

                Text {
                    x: 66px;
                    y: 288px;
                    width: parent.width - 83px;
                    height: 11px;
                    text: root.widget-symbol-status-text;
                    color: root.settings-muted-color;
                    font-size: 9px;
                    font-weight: 500;
                    overflow: elide;
                }

                Rectangle {
                    x: 0px;
                    y: 265px;
                    width: parent.width;
                    height: 1px;
                    background: root.settings-divider-color;
                }

                for symbol[index] in root.widget-symbol-chip-values : Rectangle {
                    x: root.widget-symbol-chip-x[index] * 1px;
                    y: root.widget-symbol-chip-y[index] * 1px;
                    width: root.widget-symbol-chip-width[index] * 1px;
                    height: 30px;
                    border-radius: 15px;
                    background: root.settings-selected-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    Text {
                        x: 11px;
                        y: 9px;
                        width: parent.width - 33px;
                        text: symbol;
                        color: root.settings-heading-color;
                        font-size: 10px;
                        font-weight: 500;
                        overflow: elide;
                    }

                    Text {
                        x: parent.width - 20px;
                        y: 7px;
                        width: 11px;
                        text: "x";
                        color: root.can-remove-widget-symbol ? root.settings-muted-color : root.settings-divider-color;
                        font-size: 11px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }

                    TouchArea {
                        width: parent.width - 24px;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => {
                            root.open-widget-symbol-replace-picker(index);
                        }
                    }

                    TouchArea {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        mouse-cursor: root.can-remove-widget-symbol ? pointer : default;
                        clicked => {
                            if root.can-remove-widget-symbol {
                                root.remove-widget-symbol(root.selected-widget-index, index);
                            }
                        }
                    }
                }

                Rectangle {
                    x: root.widget-symbol-add-x * 1px;
                    y: root.widget-symbol-add-y * 1px;
                    width: 69px;
                    height: 30px;
                    border-radius: 4px;
                    background: add_widget_symbol_touch.has-hover ? root.settings-selected-background : transparent;
                    border-width: 1px;
                    border-color: root.can-add-widget-symbol ? root.settings-accent-color : root.settings-divider-color;
                    visible: root.has-widgets && root.can-add-widget-symbol;

                    Text {
                        x: 0px;
                        y: 9px;
                        width: parent.width;
                        text: "+ " + root.add-widget-text;
                        color: root.can-add-widget-symbol ? root.settings-accent-color : root.settings-divider-color;
                        font-size: 10px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }

                    add_widget_symbol_touch := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: root.can-add-widget-symbol ? pointer : default;
                        clicked => {
                            if root.can-add-widget-symbol {
                                root.open-widget-symbol-picker();
                            }
                        }
                    }
                }

                Rectangle {
                    x: 0px;
                    y: root.widget-display-section-y * 1px;
                    width: parent.width;
                    height: 1px;
                    background: root.settings-divider-color;
                }

                Text {
                    x: 17px;
                    y: (root.widget-display-section-y + 20) * 1px;
                    width: parent.width - 34px;
                    height: 14px;
                    text: root.app-settings-text;
                    color: root.settings-heading-color;
                    font-size: 11px;
                    font-weight: 500;
                    overflow: elide;
                }

                SettingLabel {
                    x: 17px;
                    y: (root.widget-display-section-y + 38) * 1px;
                    width: 129px;
                    label: root.widget-theme-text;
                    help: root.widget-theme-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                    visible: root.widget-theme-control-visible;
                }

                ComboBox {
                    x: parent.width - 249px;
                    y: (root.widget-display-section-y + 36) * 1px;
                    width: 232px;
                    model: root.widget-theme-options;
                    current-index <=> root.widget-theme-index;
                    visible: root.widget-theme-control-visible;
                    enabled: root.widget-theme-control-visible;
                    selected(_) => { root.apply-current-widget-settings(); }
                }

                SettingLabel {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 142) * 1px;
                    width: parent.width - 89px;
                    label: root.widget-show-coin-logos-text;
                    help: root.widget-show-coin-logos-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                SettingSwitch {
                    x: parent.width - 54px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 148) * 1px;
                    checked <=> root.widget-show-coin-logos;
                    accent-color: root.settings-accent-color;
                    track-color: root.settings-track-color;
                    knob-color: root.settings-knob-color;
