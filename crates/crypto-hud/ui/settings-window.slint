                        knob-color: root.settings-knob-color;
                        toggled => { root.apply-current-settings(); }
                    }

                    TouchArea {
                        x: 17px;
                        y: 93px;
                        width: 358px;
                        height: 42px;
                        clicked => {
                            root.show-main-window-on-startup = !root.show-main-window-on-startup;
                            root.apply-current-settings();
                        }
                    }

                    SettingLabel {
                        x: 17px;
                        y: 143px;
                        width: 301px;
                        label: root.shortcut-text;
                        help: root.shortcut-help-text;
                        label-color: root.settings-label-color;
                        muted-color: root.settings-muted-color;
                    }

                    ComboBox {
                        x: parent.width - 201px;
                        y: 142px;
                        width: 183px;
                        model: root.shortcut-options;
                        current-index <=> root.shortcut-index;
                        selected(_) => { root.apply-current-settings(); }
                    }
                }

                Rectangle {
                    x: 0px;
                    y: 196px;
                    width: system_tab.width - 34px;
                    height: system_tab.network-proxy-card-height;
                    border-radius: 6px;
                    background: root.settings-surface-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    SettingSectionTitle {
                        x: 17px;
                        y: 13px;
                        width: parent.width - 34px;
                        title: root.network-proxy-settings-text;
                        title-color: root.settings-heading-color;
                        divider-color: root.settings-divider-color;
                    }

                    SettingSwitch {
                        x: parent.width - 54px;
                        y: 56px;
                        checked <=> root.network-proxy-enabled;
                        accent-color: root.settings-accent-color;
                        track-color: root.settings-track-color;
                        knob-color: root.settings-knob-color;
                        toggled => { root.apply-current-network-settings(); }
                    }

                    SettingLabel {
                        x: 17px;
                        y: 54px;
                        width: parent.width - 88px;
                        label: root.network-proxy-enabled-text;
                        help: root.network-proxy-help-text;
                        label-color: root.settings-label-color;
                        muted-color: root.settings-muted-color;
                    }

                    TouchArea {
                        x: 17px;
                        y: 49px;
                        width: parent.width - 88px;
                        height: 42px;
                        clicked => {
                            root.network-proxy-enabled = !root.network-proxy-enabled;
                            root.apply-current-network-settings();
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: 93px;
                        width: parent.width;
                        height: 1px;
                        background: root.settings-divider-color;
                        visible: root.network-proxy-enabled;
                    }

                    Text {
                        x: 17px;
                        y: 108px;
                        width: parent.width - 34px;
                        text: root.network-proxy-url-text;
                        color: root.settings-label-color;
                        font-size: 11px;
                        font-weight: 500;
                        overflow: elide;
                        visible: root.network-proxy-enabled;
                    }

                    LineEdit {
                        x: 17px;
                        y: 123px;
                        width: parent.width - 34px;
                        height: 26px;
                        text <=> root.network-proxy-url-input-text;
                        edited(_) => { root.apply-current-network-settings(); }
                        visible: root.network-proxy-enabled;
                    }

                    Text {
                        x: 17px;
                        y: 159px;
                        width: parent.width - 34px;
                        height: 14px;
                        text: root.network-proxy-example-hint-text;
                        color: root.settings-muted-color;
                        font-size: 10px;
                        overflow: elide;
                        visible: root.network-proxy-enabled;
                    }
                }

                Rectangle {
                    x: 0px;
                    y: system_tab.tray-card-y;
                    width: system_tab.width - 34px;
                    height: 139px;
                    border-radius: 6px;
                    background: root.settings-surface-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    SettingSectionTitle {
                        x: 17px;
                        y: 13px;
                        width: parent.width - 34px;
                        title: root.system-tray-text;
                        title-color: root.settings-heading-color;
                        divider-color: root.settings-divider-color;
                    }

                    Rectangle {
                        x: 0px;
                        y: 93px;
                        width: parent.width;
                        height: 1px;
                        background: root.settings-divider-color;
                    }

                    SettingLabel {
                        x: 17px;
                        y: 54px;
                        width: 301px;
                        label: root.tray-icon-text;
                        help: root.tray-icon-help-text;
                        label-color: root.settings-label-color;
                        muted-color: root.settings-muted-color;
                    }

                    SettingSwitch {
                        x: parent.width - 54px;
                        y: 56px;
                        checked <=> root.tray-icon-enabled;
                        accent-color: root.settings-accent-color;
                        track-color: root.settings-track-color;
                        knob-color: root.settings-knob-color;
                        toggled => { root.apply-current-settings(); }
                    }

                    TouchArea {
                        x: 17px;
                        y: 49px;
                        width: 358px;
                        height: 42px;
                        clicked => {
                            root.tray-icon-enabled = !root.tray-icon-enabled;
                            root.apply-current-settings();
                        }
                    }

                    SettingLabel {
                        x: 17px;
                        y: 99px;
                        width: 301px;
                        label: root.tray-hover-display-text;
                        help: root.tray-hover-display-help-text;
                        label-color: root.settings-label-color;
                        muted-color: root.settings-muted-color;
                    }

                    SettingSwitch {
                        x: parent.width - 54px;
                        y: 100px;
                        checked <=> root.tray-hover-display-enabled;
                        accent-color: root.settings-accent-color;
                        track-color: root.settings-track-color;
                        knob-color: root.settings-knob-color;
                        toggled => { root.apply-current-settings(); }
                    }

                    TouchArea {
                        x: 17px;
                        y: 93px;
                        width: 358px;
                        height: 42px;
                        clicked => {
                            root.tray-hover-display-enabled = !root.tray-hover-display-enabled;
                            root.apply-current-settings();
                        }
                    }
                }

                Rectangle {
                    x: 0px;
                    y: system_tab.maintenance-card-y;
                    width: system_tab.width - 34px;
                    height: 139px;
                    border-radius: 6px;
                    background: root.settings-surface-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    SettingSectionTitle {
                        x: 17px;
                        y: 13px;
                        width: parent.width - 34px;
                        title: root.system-maintenance-text;
                        title-color: root.settings-heading-color;
                        divider-color: root.settings-divider-color;
                    }

                    Rectangle {
                        x: 0px;
                        y: 93px;
                        width: parent.width;
                        height: 1px;
                        background: root.settings-divider-color;
                    }

                    SettingLabel {
                        x: 17px;
                        y: 54px;
                        width: 301px;
                        label: root.icon-cache-text;
                        help: root.icon-cache-help-text;
                        label-color: root.settings-label-color;
                        muted-color: root.settings-muted-color;
                    }

                    Button {
                        x: parent.width - 110px;
                        y: 51px;
                        width: 93px;
                        height: 24px;
                        text: root.clear-icon-cache-text;
                        clicked => { root.clear-icon-cache(); }
                    }

                    SettingLabel {
                        x: 17px;
                        y: 99px;
                        width: 301px;
                        label: root.custom-components-text;
                        help: root.custom-components-help-text;
                        label-color: root.settings-label-color;
                        muted-color: root.settings-muted-color;
                    }

                    Button {
                        x: parent.width - 110px;
                        y: 96px;
                        width: 93px;
                        height: 24px;
                        text: root.open-custom-components-folder-text;
                        clicked => { root.open-custom-components-folder(); }
                    }
                }

                Rectangle {
                    x: 0px;
                    y: system_tab.app-info-card-y;
                    width: system_tab.width - 34px;
                    height: 139px;
                    border-radius: 6px;
                    background: root.settings-surface-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    SettingSectionTitle {
                        x: 17px;
                        y: 13px;
                        width: parent.width - 34px;
                        title: root.system-app-info-text;
                        title-color: root.settings-heading-color;
                        divider-color: root.settings-divider-color;
                    }

                    Rectangle {
                        x: 0px;
                        y: 93px;
                        width: parent.width;
                        height: 1px;
                        background: root.settings-divider-color;
                    }

                    Text {
                        x: 17px;
                        y: 57px;
                        width: 301px;
                        text: root.app-version-label-text;
                        color: root.settings-label-color;
                        font-size: 10px;
                        font-weight: 700;
                        overflow: elide;
                    }

                    Text {
                        x: parent.width - 201px;
                        y: 57px;
                        width: 183px;
                        text: root.app-version-value-text;
                        color: root.settings-muted-color;
                        font-size: 10px;
                        font-weight: 700;
                        horizontal-alignment: right;
                        overflow: elide;
                    }

                    Text {
                        x: 17px;
                        y: 93px;
                        width: 301px;
                        height: 46px;
                        text: root.about-us-text;
                        color: root.settings-label-color;
                        font-size: 10px;
                        font-weight: 700;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    about_link := Rectangle {
                        x: parent.width - 201px;
                        y: 103px;
                        width: 183px;
                        height: 26px;
                        border-radius: 4px;
                        background: about_link_touch.has-hover ? root.settings-selected-background : transparent;
                        border-width: 1px;
                        border-color: about_link_touch.has-hover ? root.settings-border-color : transparent;

                        Path {
                            x: parent.width - 154px;
                            y: (parent.height - 16px) / 2;
                            width: 16px;
                            height: 16px;
                            viewbox-width: 16;
                            viewbox-height: 16;
                            commands: "M 8 0 C 3.58 0 0 3.58 0 8 C 0 11.54 2.29 14.53 5.47 15.59 C 5.87 15.66 6.02 15.42 6.02 15.21 C 6.02 15.02 6.01 14.39 6.01 13.72 C 4 14.09 3.48 13.23 3.32 12.78 C 3.23 12.55 2.84 11.84 2.5 11.65 C 2.22 11.5 1.82 11.13 2.49 11.12 C 3.12 11.11 3.57 11.7 3.72 11.94 C 4.44 13.15 5.59 12.81 6.05 12.6 C 6.12 12.08 6.33 11.73 6.56 11.53 C 4.78 11.33 2.92 10.64 2.92 7.58 C 2.92 6.71 3.23 5.99 3.74 5.43 C 3.66 5.23 3.38 4.41 3.82 3.31 C 3.82 3.31 4.49 3.1 6.02 4.13 C 6.66 3.95 7.34 3.86 8.02 3.86 C 8.7 3.86 9.38 3.95 10.02 4.13 C 11.55 3.09 12.22 3.31 12.22 3.31 C 12.66 4.41 12.38 5.23 12.3 5.43 C 12.81 5.99 13.12 6.7 13.12 7.58 C 13.12 10.65 11.25 11.33 9.47 11.53 C 9.76 11.78 10.01 12.26 10.01 13.01 C 10.01 14.08 10 14.94 10 15.21 C 10 15.42 10.15 15.67 10.55 15.59 C 13.71 14.53 16 11.53 16 8 C 16 3.58 12.42 0 8 0 Z";
                            fill: root.settings-accent-color;
                            stroke: transparent;
                        }

                        Text {
                            x: parent.width - 134px;
                            y: 0px;
                            width: 117px;
                            height: parent.height;
                            text: "crypto-widget/crypto-hud";
                            color: root.settings-accent-color;
                            font-size: 9px;
                            font-weight: 700;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        about_link_touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => { root.open-about-link(); }
                        }
                    }

                }
            }

        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 1px;
            background: root.settings-window-edge-color;
        }

        Rectangle {
            x: 0px;
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: root.settings-window-edge-color;
        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: 1px;
            height: parent.height;
            background: root.settings-window-edge-color;
        }

        Rectangle {
            x: parent.width - 1px;
            y: 0px;
            width: 1px;
            height: parent.height;
            background: root.settings-window-edge-color;
        }

    }

    Rectangle {
        visible: root.symbol-picker-open;
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: #00000088;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.close-symbol-picker(); }
        }

        Rectangle {
            x: (root.width - 344px) / 2;
            y: (root.height - 205px) / 2;
            width: 344px;
            height: 205px;
            border-radius: 6px;
            background: root.settings-surface-background;
            border-width: 1px;
            border-color: root.settings-border-color;

            Text {
                x: 17px;
                y: 14px;
                width: parent.width - 34px;
                text: root.symbol-picker-title-text;
                color: root.settings-heading-color;
                font-size: 13px;
                font-weight: 850;
                overflow: elide;
            }

            Rectangle {
                x: 0px;
                y: 43px;
                width: parent.width;
                height: 1px;
                background: root.settings-divider-color;
            }

            LineEdit {
                x: 17px;
                y: 60px;
                width: parent.width - 34px;
                height: 26px;
                text <=> root.symbol-picker-search-text;
                placeholder-text: root.symbol-search-placeholder-text;
                edited(_) => { root.refresh-symbol-picker-candidates(); }
            }

            ComboBox {
                x: 17px;
                y: 97px;
                width: parent.width - 34px;
                model: root.symbol-picker-candidate-options;
                current-index <=> root.symbol-picker-candidate-index;
                enabled: root.symbol-picker-candidate-options.length > 0;
            }

            Text {
                x: 17px;
                y: 132px;
                width: parent.width - 34px;
                height: 24px;
                text: root.symbol-picker-status-text;
                color: root.settings-muted-color;
                font-size: 9px;
                wrap: word-wrap;
            }

            Button {
                x: parent.width - 149px;
                y: parent.height - 37px;
                width: 60px;
                height: 24px;
                text: root.symbol-picker-cancel-text;
                clicked => { root.close-symbol-picker(); }
            }

            Button {
                x: parent.width - 77px;
                y: parent.height - 37px;
                width: 60px;
                height: 24px;
                text: root.symbol-picker-confirm-text;
                enabled: root.can-confirm-symbol-picker;
                clicked => {
                    if root.can-confirm-symbol-picker {
                        root.confirm-symbol-picker(root.symbol-picker-mode, root.symbol-picker-candidate-index);
                    }
                }
            }
        }
    }
}
