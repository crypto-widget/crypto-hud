                            font-size: 16px;
                            font-weight: 900;
                            overflow: elide;
                        }

                        Text {
                            x: 9px;
                            y: 44px;
                            text: plugin.symbol_limit == 1 ? "-1.36%" : "+0.03%";
                            color: plugin.symbol_limit == 1 ? #f87171 : #22c55e;
                            font-size: 10px;
                            font-weight: 800;
                        }

                        Text {
                            x: 9px;
                            y: 57px;
                            width: parent.width - 17px;
                            text: plugin.status;
                            visible: plugin.status != "";
                            color: plugin.available ? root.settings-preview-source-color : root.settings-muted-color;
                            font-size: 7px;
                            overflow: elide;
                        }
                    }

                    Rectangle {
                        x: 16px;
                        y: 42px;
                        width: 123px;
                        height: 23px;
                        border-radius: 7px;
                        background: #15212cf2;
                        border-width: 1px;
                        border-color: #62e5f0c8;
                        clip: true;
                        visible: plugin.preview_image_count <= 0 && plugin.preview_kind == 1;

                        Rectangle { width: parent.width; height: parent.height; border-radius: 7px; background: @linear-gradient(90deg, #ffffff11 0%, #ffffff07 36%, #ffffff02 58%, #00000022 100%); }
                        Rectangle { x: parent.width * 0.52; y: 1px; width: parent.width * 0.48 - 4px; height: parent.height - 3px; background: @linear-gradient(90deg, #00000000 0%, #00000016 70%, #0000002d 100%); }
                        Rectangle { y: parent.height - 6px; width: parent.width; height: 6px; background: @linear-gradient(180deg, #00000000 0%, #0000003c 100%); }

                        Text {
                            x: 6px;
                            y: 6px;
                            width: 30px;
                            text: "BTC/USDT";
                            color: root.settings-preview-primary-color;
                            font-size: 5px;
                            font-weight: 800;
                            overflow: elide;
                        }

                        Rectangle { x: 32px; y: 9px; width: 3px; height: 3px; border-radius: 1px; background: #45d980; }
                        Text { x: 6px; y: 15px; width: 21px; text: "Binance"; color: #8f9aa8; font-size: 4px; overflow: elide; }
                        Text { x: 30px; y: 15px; width: 16px; text: "3s"; color: #8f9aa8; font-size: 4px; overflow: elide; }

                        Text {
                            x: 40px;
                            y: 4px;
                            width: 44px;
                            text: "106800";
