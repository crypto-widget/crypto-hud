import { PanelTitle, SettingLabel, SettingSectionTitle, SettingsNavItem, SettingSwitch } from "shared-controls.slint";
import "fonts/NotoSansSC-wght.ttf";

component OpacitySlider inherits Rectangle {
    in-out property <int> value;
    in property <bool> enabled: true;
    in property <color> accent-color;
    in property <color> track-color;
    in property <color> knob-color;
    in property <color> disabled-color;

    property <length> knob-x: clamp((root.value - 20) * root.width / 80 - 6px, 0px, root.width - 13px);
    property <length> track-y: (root.height - 3px) / 2;

    callback changed(int);
    callback committed(int);

    height: 20px;
    background: transparent;

    function value-from-position(x: length) -> int {
        return 20 + round(clamp(x, 0px, root.width) * 80 / root.width);
    }

    function set-value-from-position(x: length) {
        if root.enabled {
            root.value = root.value-from-position(x);
            root.changed(root.value);
        }
    }

    Rectangle {
        x: 0px;
        y: root.track-y;
        width: parent.width;
        height: 3px;
        border-radius: 1px;
        background: root.enabled ? root.track-color : root.disabled-color;

        Rectangle {
            x: 0px;
            y: 0px;
            width: (root.value - 20) * parent.width / 80;
            height: parent.height;
            border-radius: parent.border-radius;
            background: root.enabled ? root.accent-color : root.disabled-color;
        }
    }

    Rectangle {
        x: root.knob-x;
        y: (parent.height - self.height) / 2;
        width: 13px;
        height: 13px;
        border-radius: 6px;
        background: root.enabled ? root.knob-color : root.disabled-color;
        border-width: 1px;
        border-color: root.enabled ? root.accent-color : root.disabled-color;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        mouse-cursor: !root.enabled ? default : (self.pressed ? grabbing : pointer);
        pointer-event(event) => {
            if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                root.set-value-from-position(self.mouse-x);
            } else if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                root.committed(root.value);
            } else if event.kind == PointerEventKind.cancel {
                root.committed(root.value);
            }
        }
        moved => {
            if self.pressed {
                root.set-value-from-position(self.mouse-x);
            }
        }
    }
}

component PercentStepper inherits Rectangle {
    in-out property <int> value;
    in property <int> minimum: 20;
    in property <int> maximum: 100;
    in property <int> step-size: 1;
    in property <bool> enabled: true;
    in property <color> text-color;
    in property <color> muted-color;
    in property <color> surface-color;
    in property <color> hover-color;
    in property <color> control-border-color;

    callback edited(int);

    width: 150px;
    height: 34px;
    border-radius: 4px;
    background: root.surface-color;
    border-width: 1px;
    border-color: root.control-border-color;

    function apply-step(delta: int) {
        if root.enabled {
            root.value = clamp(root.value + delta, root.minimum, root.maximum);
            root.edited(root.value);
        }
    }

    Text {
        x: 50px;
        y: 10px;
        width: 50px;
        height: 14px;
        text: root.value + "";
        color: root.enabled ? root.text-color : root.muted-color;
        font-size: 10px;
        font-weight: 500;
        horizontal-alignment: center;
        overflow: elide;
    }

    Rectangle {
        x: 49px;
        y: 0px;
        width: 1px;
        height: parent.height;
        background: root.control-border-color;
    }

    Rectangle {
        x: 100px;
        y: 0px;
        width: 1px;
        height: parent.height;
        background: root.control-border-color;
    }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 49px;
        height: parent.height;
        background: step_down_touch.has-hover ? root.hover-color : transparent;

        Text {
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: "-";
            color: root.enabled ? root.muted-color : root.control-border-color;
            font-size: 13px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        step_down_touch := TouchArea {
            width: parent.width;
            height: parent.height;
            enabled: root.enabled;
            mouse-cursor: root.enabled ? pointer : default;
            clicked => { root.apply-step(-root.step-size); }
        }
    }

    Rectangle {
        x: 101px;
        y: 0px;
        width: parent.width - 101px;
        height: parent.height;
        background: step_up_touch.has-hover ? root.hover-color : transparent;

        Text {
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: "+";
            color: root.enabled ? root.muted-color : root.control-border-color;
            font-size: 13px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        step_up_touch := TouchArea {
            width: parent.width;
            height: parent.height;
            enabled: root.enabled;
            mouse-cursor: root.enabled ? pointer : default;
            clicked => { root.apply-step(root.step-size); }
        }
    }
}

component SettingsSmallButton inherits Rectangle {
    in property <string> text;
    in property <color> text-color;
    in property <color> muted-color;
    in property <color> surface-color;
    in property <color> hover-color;
    in property <color> control-border-color;
    in property <bool> enabled: true;
    callback clicked();

    width: 54px;
    height: 23px;
    border-radius: 4px;
    background: action_touch.has-hover && root.enabled ? root.hover-color : root.surface-color;
    border-width: 1px;
    border-color: root.control-border-color;

    Text {
        x: 6px;
        y: (parent.height - self.height) / 2;
        width: parent.width - 11px;
        height: 13px;
        text: root.text;
        color: root.enabled ? root.text-color : root.muted-color;
        font-size: 10px;
        font-weight: 500;
        horizontal-alignment: center;
        overflow: elide;
    }

    action_touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }
}

component GithubProjectSignature inherits Rectangle {
    in property <string> project-name;
    in property <string> version-text;
    in property <string> status-text;
    in property <color> label-color;
    in property <color> muted-color;
    in property <color> accent-color;
    callback clicked();

    property <bool> has-status: root.status-text != "";
    property <color> active-label-color: signature_touch.has-hover ? root.accent-color : root.label-color;
    property <length> lockup-width: root.has-status ? root.width : 96px;
    property <length> lockup-x: (root.width - root.lockup-width) / 2;
    property <length> lockup-y: (root.height - 32px) / 2;

    background: transparent;

    Path {
        x: root.lockup-x;
        y: root.lockup-y + 6px;
        width: 19px;
        height: 19px;
        viewbox-width: 16;
        viewbox-height: 16;
        commands: "M 8 0 C 3.58 0 0 3.58 0 8 C 0 11.54 2.29 14.53 5.47 15.59 C 5.87 15.66 6.02 15.42 6.02 15.21 C 6.02 15.02 6.01 14.39 6.01 13.72 C 4 14.09 3.48 13.23 3.32 12.78 C 3.23 12.55 2.84 11.84 2.5 11.65 C 2.22 11.5 1.82 11.13 2.49 11.12 C 3.12 11.11 3.57 11.7 3.72 11.94 C 4.44 13.15 5.59 12.81 6.05 12.6 C 6.12 12.08 6.33 11.73 6.56 11.53 C 4.78 11.33 2.92 10.64 2.92 7.58 C 2.92 6.71 3.23 5.99 3.74 5.43 C 3.66 5.23 3.38 4.41 3.82 3.31 C 3.82 3.31 4.49 3.1 6.02 4.13 C 6.66 3.95 7.34 3.86 8.02 3.86 C 8.7 3.86 9.38 3.95 10.02 4.13 C 11.55 3.09 12.22 3.31 12.22 3.31 C 12.66 4.41 12.38 5.23 12.3 5.43 C 12.81 5.99 13.12 6.7 13.12 7.58 C 13.12 10.65 11.25 11.33 9.47 11.53 C 9.76 11.78 10.01 12.26 10.01 13.01 C 10.01 14.08 10 14.94 10 15.21 C 10 15.42 10.15 15.67 10.55 15.59 C 13.71 14.53 16 11.53 16 8 C 16 3.58 12.42 0 8 0 Z";
        fill: root.active-label-color;
        stroke: transparent;
    }

    Text {
        x: root.lockup-x + 29px;
        y: root.lockup-y + 2px;
        width: root.lockup-width - 29px;
        height: 14px;
        text: root.project-name;
        color: root.active-label-color;
        font-size: 11px;
        font-weight: 800;
        overflow: elide;
    }

    Text {
        x: root.lockup-x + 29px;
        y: root.lockup-y + 20px;
        width: root.has-status ? 47px : root.lockup-width - 29px;
        height: 12px;
        text: "v" + root.version-text;
        color: root.muted-color;
        font-size: 9px;
        font-weight: 600;
        overflow: elide;
    }

    Rectangle {
        x: root.lockup-x + 83px;
        y: root.lockup-y + 25px;
        width: 4px;
        height: 4px;
        border-radius: 2px;
        background: root.accent-color;
        visible: root.has-status;
    }

    Text {
        x: root.lockup-x + 93px;
        y: root.lockup-y + 20px;
        width: root.lockup-width - 93px;
        height: 12px;
        text: root.status-text;
        color: root.muted-color;
        font-size: 9px;
        font-weight: 600;
        horizontal-alignment: right;
        overflow: elide;
        visible: root.has-status;
    }

    signature_touch := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component PluginPreviewCarousel inherits Rectangle {
    in property <PluginMarketItem> plugin;
    in property <color> surface-color;
    in property <color> muted-color;
    in property <color> accent-color;
    in property <color> fallback-background;
    in property <color> fallback-text-color;

    property <int> preview-count: root.plugin.preview_image_count < 5 ? root.plugin.preview_image_count : 5;
    property <int> active-index: root.preview-count <= 0 ? 0 : Math.mod(root.plugin.preview_frame_index, root.preview-count);

    border-radius: 6px;
    background: root.surface-color;
    clip: true;
    visible: root.preview-count > 0;

    Image {
        width: parent.width;
        height: parent.height;
        source: root.plugin.preview_image_1;
        image-fit: contain;
        visible: root.preview-count > 0 && root.active-index == 0;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.plugin.preview_image_2;
        image-fit: contain;
        visible: root.preview-count > 1 && root.active-index == 1;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.plugin.preview_image_3;
        image-fit: contain;
        visible: root.preview-count > 2 && root.active-index == 2;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.plugin.preview_image_4;
        image-fit: contain;
        visible: root.preview-count > 3 && root.active-index == 3;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.plugin.preview_image_5;
        image-fit: contain;
        visible: root.preview-count > 4 && root.active-index == 4;
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.fallback-background;
        visible: root.preview-count <= 0;

        Text {
            x: 8px;
            y: 27px;
            width: parent.width - 16px;
            height: 14px;
            text: root.plugin.builtin ? "HUD" : "SLINT";
            color: root.fallback-text-color;
            font-size: 10px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    for dot[index] in 5 : Rectangle {
        x: parent.width - root.preview-count * 8px + index * 8px - 3px;
        y: parent.height - 9px;
        width: 4px;
        height: 4px;
        border-radius: 2px;
        background: index == root.active-index ? root.accent-color : root.muted-color;
        visible: root.preview-count > 1 && index < root.preview-count;
    }
}

component WidgetListPreviewCarousel inherits Rectangle {
    in property <int> image-count;
    in property <image> preview-image-a;
    in property <image> preview-image-b;
    in property <image> preview-image-c;
    in property <image> preview-image-d;
    in property <image> preview-image-e;
    in property <int> frame-index;
    in property <color> surface-color;
    in property <color> preview-border-color;
    in property <color> muted-color;
    in property <color> accent-color;
    in property <color> fallback-background;
    in property <color> fallback-text-color;

    property <int> preview-count: root.image-count < 5 ? root.image-count : 5;
    property <int> active-index: root.preview-count <= 0 ? 0 : Math.mod(root.frame-index, root.preview-count);

    border-radius: 4px;
    background: root.surface-color;
    border-width: 1px;
    border-color: root.preview-border-color;
    clip: true;

    Image {
        width: parent.width;
        height: parent.height;
        source: root.preview-image-a;
        image-fit: contain;
        visible: root.preview-count > 0 && root.active-index == 0;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.preview-image-b;
        image-fit: contain;
        visible: root.preview-count > 1 && root.active-index == 1;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.preview-image-c;
        image-fit: contain;
        visible: root.preview-count > 2 && root.active-index == 2;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.preview-image-d;
        image-fit: contain;
        visible: root.preview-count > 3 && root.active-index == 3;
    }

    Image {
        width: parent.width;
        height: parent.height;
        source: root.preview-image-e;
        image-fit: contain;
        visible: root.preview-count > 4 && root.active-index == 4;
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.fallback-background;
        visible: root.preview-count <= 0;

        Text {
            x: 7px;
            y: 16px;
            width: parent.width - 14px;
            height: 12px;
            text: "HUD";
            color: root.fallback-text-color;
            font-size: 8px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    for dot[index] in 5 : Rectangle {
        x: parent.width - root.preview-count * 6px + index * 6px - 2px;
        y: parent.height - 7px;
        width: 3px;
        height: 3px;
        border-radius: 1px;
        background: index == root.active-index ? root.accent-color : root.muted-color;
        visible: root.preview-count > 1 && index < root.preview-count;
    }
}

