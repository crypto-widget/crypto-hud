                TouchArea {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 130) * 1px;
                    width: parent.width - 89px;
                    height: 47px;
                    clicked => {
                        root.widget-show-coin-logos = !root.widget-show-coin-logos;
                        root.apply-current-widget-settings();
                    }
                }

                SettingLabel {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 192) * 1px;
                    width: parent.width - 89px;
                    label: root.widget-hide-quote-asset-text;
                    help: root.widget-hide-quote-asset-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                SettingSwitch {
                    x: parent.width - 54px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 198) * 1px;
                    checked <=> root.widget-hide-quote-asset;
                    accent-color: root.settings-accent-color;
                    track-color: root.settings-track-color;
                    knob-color: root.settings-knob-color;
                    toggled => { root.apply-current-widget-settings(); }
                }

                TouchArea {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 180) * 1px;
                    width: parent.width - 89px;
                    height: 47px;
                    clicked => {
                        root.widget-hide-quote-asset = !root.widget-hide-quote-asset;
                        root.apply-current-widget-settings();
                    }
                }

                SettingLabel {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 38) * 1px;
                    width: 129px;
                    label: root.widget-scale-text;
                    help: root.widget-scale-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                PercentStepper {
                    x: parent.width - 264px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 38) * 1px;
                    width: 150px;
                    height: 34px;
                    enabled: root.has-widgets;
                    minimum: root.widget-scale-min-percent;
                    maximum: root.widget-scale-max-percent;
                    step-size: 5;
                    value <=> root.widget-scale-percent;
                    text-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                    surface-color: root.settings-content-background;
                    hover-color: root.settings-selected-background;
                    control-border-color: root.settings-border-color;
                    edited(value) => {
                        if root.has-widgets && root.selected-widget-index >= 0 {
                            root.apply-widget-scale(root.selected-widget-index, value);
                        }
                    }
                }

                Text {
                    x: parent.width - 106px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 49) * 1px;
                    width: 17px;
                    text: "%";
                    color: root.settings-muted-color;
                    font-size: 10px;
                    font-weight: 500;
                }

                SettingsSmallButton {
                    x: parent.width - 81px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 38) * 1px;
                    width: 64px;
                    height: 34px;
                    text: root.reset-text;
                    text-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                    surface-color: root.settings-content-background;
                    hover-color: root.settings-selected-background;
                    control-border-color: root.settings-border-color;
                    enabled: root.has-widgets;
                    clicked => {
                        root.widget-scale-percent = 100;
                        if root.has-widgets && root.selected-widget-index >= 0 {
                            root.apply-widget-scale(root.selected-widget-index, 100);
                        }
                    }
                }

                SettingLabel {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 90) * 1px;
                    width: 115px;
                    label: root.opacity-text;
                    help: root.opacity-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                OpacitySlider {
                    x: 193px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 97) * 1px;
                    width: 179px;
                    height: 20px;
                    value <=> root.opacity-percent;
                    enabled: root.has-widgets;
                    accent-color: root.settings-accent-color;
                    track-color: root.settings-track-color;
                    knob-color: root.settings-knob-color;
                    disabled-color: root.settings-divider-color;
                    changed(value) => {
                        root.opacity-percent = value;
                    }
                    committed(value) => {
                        root.opacity-percent = value;
                        root.apply-current-widget-settings();
                    }
                }

                Rectangle {
                    x: parent.width - 103px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 90) * 1px;
                    width: 50px;
                    height: 34px;
                    border-radius: 4px;
                    background: root.settings-content-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    Text {
                        x: 6px;
                        y: 10px;
                        width: parent.width - 11px;
                        text: root.opacity-percent + "";
                        color: root.settings-label-color;
                        font-size: 10px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }

                Text {
                    x: parent.width - 42px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 101) * 1px;
                    width: 9px;
                    height: 13px;
                    text: "%";
                    color: root.settings-muted-color;
                    font-size: 10px;
                    font-weight: 500;
                    overflow: elide;
                }

                Rectangle {
                    x: 0px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 239) * 1px;
                    width: parent.width;
                    height: 1px;
                    background: root.settings-divider-color;
                }

                Text {
                    x: 17px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 257) * 1px;
                    width: parent.width - 52px;
                    height: 13px;
                    text: root.advanced-options-text;
                    color: root.settings-muted-color;
                    font-size: 11px;
                    font-weight: 500;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 34px;
                    y: (root.widget-display-section-y + root.widget-theme-settings-offset + 253) * 1px;
                    width: 17px;
                    height: 17px;
                    text: ">";
                    color: root.settings-divider-color;
                    font-size: 14px;
                    font-weight: 500;
                    horizontal-alignment: center;
                    visible: false;
                }

                    }
                }

            }

            Rectangle {
                x: 315px;
                y: 16px;
                width: 344px;
                height: 433px;
                border-radius: 4px;
                background: root.settings-surface-background;
                border-width: 1px;
