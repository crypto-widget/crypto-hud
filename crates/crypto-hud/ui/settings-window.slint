                            font-size: 5px;
                            font-weight: 900;
                            horizontal-alignment: center;
                            overflow: elide;
                        }

                        Path {
                            x: 100px;
                            y: 6px;
                            width: 19px;
                            height: 11px;
                            viewbox-width: 52;
                            viewbox-height: 32;
                            commands: "M 0 32 L 0 28 L 5 23 L 10 25 L 14 21 L 19 18 L 23 20 L 28 14 L 32 17 L 37 11 L 41 16 L 46 8 L 50 0 L 52 4";
                            fill: @linear-gradient(180deg, #22c55e46 0%, #16a34a00 100%);
                            stroke: #45d980;
                            stroke-width: 2px;
                            stroke-line-cap: round;
                            stroke-line-join: round;
                        }
                    }

                    Rectangle {
                        x: 16px;
                        y: 17px;
                        width: 123px;
                        height: 72px;
                        border-radius: 6px;
