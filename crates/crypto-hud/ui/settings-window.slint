                        accent-color: root.settings-accent-color;
                        fallback-background: root.settings-preview-card-background;
                        fallback-text-color: root.settings-preview-primary-color;
                    }

                    Text {
                        x: 161px;
                        y: 17px;
                        width: parent.width - 288px;
                        text: plugin.title;
                        color: plugin.available ? root.settings-heading-color : root.settings-muted-color;
                        font-size: 13px;
                        font-weight: 800;
                        overflow: elide;
                    }

                    Text {
                        x: 161px;
                        y: 40px;
                        width: parent.width - 288px;
