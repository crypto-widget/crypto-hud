                        Path { x: 113px; y: 5px; width: 6px; height: 6px; viewbox-width: 24; viewbox-height: 24; commands: "M 5 5 L 19 19 M 19 5 L 5 19"; fill: transparent; stroke: #a7b0bf; stroke-width: 2px; stroke-line-cap: round; }
                        Rectangle { x: 7px; y: 16px; width: parent.width - 14px; height: 1px; background: #ffffff18; }

                        Text {
