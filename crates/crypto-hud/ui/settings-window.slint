                            overflow: elide;
                        }

                        Path {
                            x: 7px;
                            y: 43px;
                            width: 109px;
                            height: 16px;
                            viewbox-width: 152;
                            viewbox-height: 26;
                            commands: "M 0 26 L 0 17 L 8 9 L 14 6 L 22 13 L 32 15 L 42 11 L 51 14 L 62 10 L 73 12 L 85 8 L 96 11 L 107 7 L 118 9 L 130 6 L 142 8 L 152 3 L 152 26 Z";
                            fill: #14b8a633;
                            stroke-width: 0px;
                        }

                        Path {
                            x: 7px;
                            y: 43px;
                            width: 109px;
                            height: 16px;
                            viewbox-width: 152;
                            viewbox-height: 26;
                            commands: "M 0 17 L 8 9 L 14 6 L 22 13 L 32 15 L 42 11 L 51 14 L 62 10 L 73 12 L 85 8 L 96 11 L 107 7 L 118 9 L 130 6 L 142 8 L 152 3";
                            fill: transparent;
                            stroke: #50df99;
                            stroke-width: 1px;
                            stroke-line-cap: round;
                            stroke-line-join: round;
                        }

                        Rectangle { x: 7px; y: 62px; width: parent.width - 14px; height: 1px; background: #ffffff18; }
                        Path { x: 8px; y: 64px; width: 6px; height: 6px; viewbox-width: 24; viewbox-height: 24; commands: "M 19 12 A 7 7 0 1 1 17 7 M 17 7 L 17 3 M 17 7 L 21 7"; fill: transparent; stroke: #55e6d0; stroke-width: 2px; stroke-line-cap: round; stroke-line-join: round; }
                        Text { x: 17px; y: 64px; width: 39px; text: root.preview-updated-text; color: root.settings-preview-source-color; font-size: 4px; overflow: elide; }
                        Text { x: 80px; y: 64px; width: 34px; text: root.preview-source-ok-text; color: root.settings-preview-updated-color; font-size: 4px; horizontal-alignment: right; overflow: elide; }
                    }

                    Rectangle {
                        x: 42px;
                        y: 11px;
                        width: 80px;
                        height: 80px;
                        border-radius: 40px;
                        background: transparent;
                        clip: true;
                        visible: plugin.preview_image_count <= 0 && plugin.preview_kind == 5;

                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: @image-url("../plugins/com.cryptohud.market-compass/ui/reference.png");
                            image-fit: fill;
                        }

                        Rectangle { width: parent.width; height: parent.height; border-radius: 40px; background: transparent; border-width: 1px; border-color: #55e6d0cc; }
                    }

                    Rectangle {
                        x: 16px;
                        y: 34px;
                        width: 123px;
                        height: 39px;
                        border-radius: 6px;
                        background: transparent;
                        border-width: 1px;
                        border-color: #67e8f9aa;
                        clip: true;
                        visible: plugin.preview_image_count <= 0 && plugin.preview_kind == 6;

                        Rectangle { width: parent.width; height: parent.height; background: @linear-gradient(20deg, #0c0f16 0%, #1c242e 100%); }
                        Rectangle { x: 0px; y: 9px; width: parent.width; height: 1px; background: #ffffff16; }
                        Rectangle { x: 0px; y: 26px; width: parent.width; height: 1px; background: #ffffff16; }
                        Rectangle { x: 0px; y: 0px; width: 25px; height: parent.height; background: #15a6c5; }
                        Rectangle { x: 25px; y: 0px; width: 24px; height: parent.height; background: #2785c8; }
                        Rectangle { x: 49px; y: 0px; width: 25px; height: parent.height; background: #f0741a; }
                        Rectangle { x: 75px; y: 0px; width: 24px; height: parent.height; background: #d6c81c; }
                        Rectangle { x: 99px; y: 0px; width: 24px; height: parent.height; background: #2fa05d; }

                        Rectangle {
                            width: parent.width;
                            height: 16px;
                            background: @linear-gradient(180deg, #ffffff66 0%, #ffffff22 46%, #ffffff00 100%);
                        }

                        Text { x: 5px; y: 6px; width: 20px; text: "BTC"; color: #ffffff; font-size: 5px; font-weight: 900; overflow: elide; }
                        Text { x: 5px; y: 18px; width: 23px; text: "106k"; color: #ffffff; font-size: 6px; font-weight: 900; overflow: elide; }
                        Text { x: 30px; y: 18px; width: 19px; text: "2.4k"; color: #ffffff; font-size: 6px; font-weight: 900; overflow: elide; }
                        Text { x: 54px; y: 18px; width: 19px; text: "136"; color: #ffffff; font-size: 6px; font-weight: 900; overflow: elide; }
                        Text { x: 79px; y: 18px; width: 19px; text: "642"; color: #111827; font-size: 6px; font-weight: 900; overflow: elide; }
                        Text { x: 104px; y: 18px; width: 16px; text: "2.1"; color: #ffffff; font-size: 6px; font-weight: 900; overflow: elide; }
                    }

                    PluginPreviewCarousel {
                        x: 16px;
                        y: 17px;
                        width: 123px;
                        height: 72px;
                        plugin: plugin;
                        surface-color: root.settings-surface-background;
