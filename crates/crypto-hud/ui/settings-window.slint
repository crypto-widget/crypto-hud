                    help: root.refresh-interval-help-text;
                    label-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                }

                PercentStepper {
                    x: parent.width - 207px;
                    y: 96px;
                    width: 150px;
                    height: 34px;
                    enabled: true;
                    minimum: 5;
                    maximum: 60;
                    step-size: 1;
                    value <=> root.refresh-interval-seconds;
                    text-color: root.settings-label-color;
                    muted-color: root.settings-muted-color;
                    surface-color: root.settings-content-background;
                    hover-color: root.settings-selected-background;
                    control-border-color: root.settings-border-color;
                    edited(_) => { root.apply-current-settings(); }
                }

                Text {
                    x: parent.width - 49px;
                    y: 96px;
                    width: 32px;
                    height: 34px;
                    text: root.seconds-unit-text;
                    color: root.settings-muted-color;
                    font-size: 9px;
                    font-weight: 700;
                    vertical-alignment: center;
                    overflow: elide;
                }

            }

            Rectangle {
                x: 17px;
                y: 215px;
                width: market_tab.width - 34px;
                height: 104px;
                border-radius: 6px;
                background: root.settings-surface-background;
                border-width: 1px;
                border-color: root.settings-border-color;

                SettingSectionTitle {
                    x: 17px;
                    y: 13px;
                    width: parent.width - 34px;
                    title: root.default-symbols-text;
                    title-color: root.settings-heading-color;
                    divider-color: root.settings-divider-color;
                }

                for symbol[index] in root.default-symbol-chip-values : Rectangle {
                    x: 17px + index * 92px;
                    y: 54px;
                    width: 84px;
                    height: 30px;
                    border-radius: 15px;
                    background: root.settings-selected-background;
                    border-width: 1px;
                    border-color: root.settings-border-color;

                    Text {
                        x: 11px;
                        y: 9px;
                        width: parent.width - 33px;
                        text: symbol;
                        color: root.settings-heading-color;
                        font-size: 10px;
                        font-weight: 500;
                        overflow: elide;
                    }

                    Text {
                        x: parent.width - 20px;
                        y: 7px;
                        width: 11px;
                        text: "x";
                        color: root.can-remove-default-symbol ? root.settings-muted-color : root.settings-divider-color;
                        font-size: 11px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }

                    TouchArea {
                        width: parent.width - 24px;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => {
                            root.open-default-symbol-replace-picker(index);
                        }
                    }

                    TouchArea {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        mouse-cursor: root.can-remove-default-symbol ? pointer : default;
                        clicked => {
                            if root.can-remove-default-symbol {
                                root.remove-default-symbol(index);
                            }
                        }
                    }
                }

                Rectangle {
                    x: 17px + root.default-symbol-chip-values.length * 92px;
                    y: 54px;
                    width: 69px;
                    height: 30px;
                    border-radius: 4px;
                    background: add_default_symbol_touch.has-hover ? root.settings-selected-background : transparent;
                    border-width: 1px;
                    border-color: root.can-add-default-symbol ? root.settings-accent-color : root.settings-divider-color;
                    visible: root.can-add-default-symbol;

                    Text {
                        x: 0px;
                        y: 9px;
                        width: parent.width;
                        text: "+ " + root.add-widget-text;
                        color: root.can-add-default-symbol ? root.settings-accent-color : root.settings-divider-color;
                        font-size: 10px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }

                    add_default_symbol_touch := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: root.can-add-default-symbol ? pointer : default;
                        clicked => {
                            if root.can-add-default-symbol {
                                root.open-default-symbol-picker();
                            }
                        }
                    }
                }

            }
        }

