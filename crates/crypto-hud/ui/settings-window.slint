                        Rectangle { x: 7px; y: 49px; width: 109px; height: 1px; background: #ffffff12; }

                        Text { x: 7px; y: 21px; width: 34px; text: "BTC"; color: root.settings-preview-primary-color; font-size: 6px; font-weight: 800; overflow: elide; }
                        Text { x: 47px; y: 20px; width: 36px; text: "106800"; color: root.settings-preview-primary-color; font-size: 7px; font-weight: 800; horizontal-alignment: right; overflow: elide; }
                        Text { x: 88px; y: 21px; width: 27px; text: "+0.03%"; color: #22c55e; font-size: 6px; font-weight: 800; horizontal-alignment: right; overflow: elide; }

                        Text { x: 7px; y: 37px; width: 34px; text: "ETH"; color: root.settings-preview-primary-color; font-size: 6px; font-weight: 800; overflow: elide; }
                        Text { x: 47px; y: 37px; width: 36px; text: "3,583"; color: root.settings-preview-primary-color; font-size: 7px; font-weight: 800; horizontal-alignment: right; overflow: elide; }
                        Text { x: 88px; y: 37px; width: 27px; text: "+1.85%"; color: #22c55e; font-size: 6px; font-weight: 800; horizontal-alignment: right; overflow: elide; }

                        Text { x: 7px; y: 54px; width: 34px; text: "XRP"; color: root.settings-preview-primary-color; font-size: 6px; font-weight: 800; overflow: elide; }
                        Text { x: 47px; y: 53px; width: 36px; text: "1.06"; color: root.settings-preview-primary-color; font-size: 7px; font-weight: 800; horizontal-alignment: right; overflow: elide; }
                        Text { x: 88px; y: 54px; width: 27px; text: "-2.93%"; color: #f87171; font-size: 6px; font-weight: 800; horizontal-alignment: right; overflow: elide; }
