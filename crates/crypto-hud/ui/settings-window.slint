                        font-size: 9px;
                        font-weight: 700;
                        overflow: elide;
                    }

                    Button {
                        x: parent.width - 104px;
                        y: 41px;
                        width: 80px;
                        height: 24px;
                        text: root.add-widget-text;
                        enabled: plugin.available;
                        primary: true;
                        clicked => {
                            if plugin.available {
                                root.add-widget(index);
                                root.settings-tab-index = 0;
                            }
                        }
                    }
                }
            }
        }

        market_tab := Rectangle {
            x: 179px;
            y: 53px;
