export struct QuoteRow {
    symbol: string,
    price: string,
    change: string,
    positive: bool,
}

export component TrustCard inherits Window {
    in property <string> widget-id;
    in property <[QuoteRow]> quote-rows;
    in property <string> pairs-heading-text;
    in property <string> source-text;
    in property <string> source-name-text;
    in property <string> updated-text;
    in property <string> empty-text;
    in property <bool> pin-to-top;
    in property <bool> layout-locked;
    in property <int> widget-width: 520;
    in property <int> widget-height: 386;
    in property <float> widget-scale: 1.0;
    in property <bool> red-up-enabled;
    in property <int> content-opacity;
    in property <string> theme-name: "dark";
    property <bool> light-theme: root.theme-name == "light";
    property <color> card-background: root.light-theme ? #f8faf0f2 : #070d14f2;
    property <color> card-header-background: root.light-theme ? #dff6f0dd : #0f172acc;
    property <color> card-border-color: root.light-theme ? #0f8f82aa : #4ddde6cc;
    property <color> card-primary-text-color: root.light-theme ? #0f172a : #f8fafc;
    property <color> card-source-text-color: root.light-theme ? #0369a1 : #cbd5e1;
    property <color> card-updated-text-color: root.light-theme ? #64748b : #9aa4b2;
    property <color> gain-color: root.light-theme ? #16a34a : #50df99;
    property <color> loss-color: root.light-theme ? #dc2626 : #ff6b76;
    in property <string> chart-line-path;
    in property <string> chart-fill-path;
    in property <bool> chart-ready;
    in property <int> chart-end-y-ratio: 500;
    in property <bool> chart-positive;
    in-out property <bool> card-left-drag-active: false;
    property <color> chart-color: root.chart-positive
        ? (root.red-up-enabled ? root.loss-color : root.gain-color)
        : (root.red-up-enabled ? root.gain-color : root.loss-color);
    property <color> chart-glow-color: root.light-theme ? #16a34a4c : #42e6c455;
    property <color> chart-fill-color: root.light-theme ? #16a34a30 : #14b8a633;
    property <float> content-scale: root.widget-scale;

    callback drag-move(length, length);
    callback toggle-layout-lock();
    function s(value: length) -> length {
        return value * root.content-scale;
    }
    title: root.widget-id;
    width: root.widget-width * 1px;
    height: root.widget-height * 1px;
    no-frame: true;
    always-on-top: root.pin-to-top;
    background: transparent;

    drag_area := TouchArea {
        width: root.widget-width * 1px;
        height: root.widget-height * 1px;
        mouse-cursor: root.layout-locked ? default : (self.pressed ? grabbing : grab);
        pointer-event(event) => {
            if !root.layout-locked && event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                root.card-left-drag-active = true;
            } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                root.card-left-drag-active = false;
            }
        }
        moved => {
            if !root.layout-locked && root.card-left-drag-active {
                root.drag-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
            }
        }
    }

    card := Rectangle {
        x: (root.widget-width * 1px - root.s(520px)) / 2 + root.s(20px);
        y: (root.widget-height * 1px - root.s(386px)) / 2 + root.s(20px);
        width: root.s(480px);
        height: root.s(351px);
        border-radius: root.s(13px);
        background: root.card-background;
        border-width: root.s(1px);
        border-color: root.card-border-color;
        opacity: root.content-opacity / 100;
        drop-shadow-offset-y: root.s(18px);
        drop-shadow-blur: root.s(28px);
        drop-shadow-color: #0000007a;
        clip: true;

        Rectangle {
            width: parent.width;
            height: parent.height;
            border-radius: root.s(13px);
            background: #ffffff07;
        }

        for quote[index] in root.quote-rows : Rectangle {
            width: parent.width;
            height: parent.height;
            visible: index == 0;

            Text {
                x: root.s(26px);
                y: root.s(24px);
                width: root.s(190px);
                text: quote.symbol;
                color: root.card-primary-text-color;
                font-size: root.s(25px);
                font-weight: 800;
                overflow: elide;
            }

            pill := Rectangle {
                x: root.s(238px);
                y: root.s(17px);
                width: root.s(136px);
                height: root.s(32px);
                border-radius: root.s(13px);
                background: #064e3b48;
                border-width: root.s(1px);
                border-color: #10b98199;

                Rectangle {
                    x: root.s(15px);
                    y: root.s(11px);
                    width: root.s(10px);
                    height: root.s(10px);
                    border-radius: root.s(5px);
                    background: root.gain-color;
                    drop-shadow-offset-y: 0px;
                    drop-shadow-blur: root.s(8px);
                    drop-shadow-color: #50df99aa;
                }

                Text {
                    x: root.s(36px);
                    y: root.s(6px);
                    width: root.s(92px);
                    text: root.source-name-text;
                    color: root.gain-color;
                    font-size: root.s(17px);
                    font-weight: 800;
                    overflow: elide;
                }
            }

            Rectangle {
                x: root.s(24px);
                y: root.s(70px);
                width: parent.width - root.s(48px);
                height: root.s(1px);
                background: #ffffff18;
            }

            Text {
                x: root.s(26px);
                y: root.s(88px);
                width: parent.width - root.s(52px);
                text: quote.price;
                color: root.card-primary-text-color;
                font-size: root.s(64px);
                font-weight: 900;
                overflow: elide;
            }

            Text {
                x: root.s(28px);
                y: root.s(158px);
                width: root.s(174px);
                text: quote.change;
                color: root.chart-color;
                font-size: root.s(27px);
                font-weight: 800;
                overflow: elide;
            }

            chart := Rectangle {
                x: root.s(24px);
                y: root.s(198px);
                width: parent.width - root.s(48px);
                height: root.s(94px);
                background: transparent;

                Path {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: root.s(90px);
                    viewbox-width: 100;
                    viewbox-height: 40;
                    fit: fill;
                    commands: root.chart-fill-path;
                    fill: root.chart-fill-color;
                    stroke-width: 0px;
                    opacity: root.chart-ready ? 1 : 0.36;
                }

                Path {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: root.s(90px);
                    viewbox-width: 100;
                    viewbox-height: 40;
                    fit: fill;
                    commands: root.chart-line-path;
                    fill: transparent;
                    stroke: root.chart-color;
                    stroke-width: root.s(2.4px);
                    stroke-line-cap: round;
                    stroke-line-join: round;
                    opacity: root.chart-ready ? 1 : 0.42;
                }

                Rectangle {
                    x: parent.width - root.s(13px);
                    y: root.chart-end-y-ratio * parent.height / 1000 - root.s(6px);
                    width: root.s(13px);
                    height: root.s(13px);
                    border-radius: root.s(6.5px);
                    background: root.chart-glow-color;
                    border-width: root.s(2px);
                    border-color: root.chart-color;
                    opacity: root.chart-ready ? 1 : 0.38;
                }
            }

            Rectangle {
                x: root.s(24px);
                y: root.s(304px);
                width: parent.width - root.s(48px);
                height: root.s(1px);
                background: root.light-theme ? #0f172a18 : #ffffff18;
            }

            refresh_icon := Path {
                x: root.s(28px);
                y: root.s(318px);
                width: root.s(21px);
                height: root.s(21px);
                viewbox-width: 24;
                viewbox-height: 24;
                commands: "M 19 12 A 7 7 0 1 1 17 7 M 17 7 L 17 3 M 17 7 L 21 7 M 10 12 L 14 12 M 12 10 L 12 14";
                fill: transparent;
                stroke: #55e6d0;
                stroke-width: root.s(2.2px);
                stroke-line-cap: round;
                stroke-line-join: round;
            }

            Text {
                x: root.s(62px);
                y: root.s(316px);
                width: root.s(150px);
                text: root.updated-text;
                color: root.card-source-text-color;
                font-size: root.s(18px);
                font-weight: 500;
                overflow: elide;
            }

        }

        Text {
            x: root.s(28px);
            y: root.s(150px);
            width: parent.width - root.s(56px);
            text: root.empty-text;
            color: root.card-updated-text-color;
            font-size: root.s(18px);
            horizontal-alignment: center;
            visible: root.quote-rows.length == 0;
            overflow: elide;
        }

        lock_button := Rectangle {
            x: parent.width - root.s(52px);
            y: root.s(16px);
            width: root.s(34px);
            height: root.s(34px);
            border-radius: root.s(9px);
            background: root.layout-locked || lock_touch.has-hover ? #07111dcc : transparent;
            border-width: root.s(1px);
            border-color: root.layout-locked || lock_touch.has-hover ? #ffffff66 : transparent;
            visible: drag_area.has-hover || lock_touch.has-hover;

            Path {
                x: root.s(5px);
                y: root.s(4px);
                width: root.s(24px);
                height: root.s(25px);
                viewbox-width: 24;
                viewbox-height: 24;
                commands: "M 8 4 L 16 4 L 16 6 L 15 6 L 15 12 L 18 14 L 18 16 L 13 16 L 13 21 L 11 21 L 11 16 L 6 16 L 6 14 L 9 12 L 9 6 L 8 6 Z";
                fill: root.layout-locked ? #a7b0bf : transparent;
                stroke: #a7b0bf;
                stroke-width: root.s(2px);
                stroke-line-cap: round;
                stroke-line-join: round;
            }

            lock_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.toggle-layout-lock(); }
            }
        }




    }
}
