{
  "schemaVersion": 3,
  "id": "com.cryptohud.market-board",
  "name": "Market Board",
  "version": "1.0.0",
  "hostApiVersion": ">=0.1.0, <1.0.0",
  "renderer": {
    "kind": "slint",
    "entry": "ui/main.slint",
    "component": "MarketBoard"
  },
  "permissions": {
    "network": false,
    "filesystem": false
  },
  "defaultSize": {
    "width": 300,
    "height": 250
  },
  "minSymbolLimit": 1,
  "symbolLimit": 5,
  "defaultSymbols": [
    "binance:spot:BTC/USDT",
    "binance:spot:ETH/USDT",
    "binance:spot:SOL/USDT"
  ],
  "themes": [
    {
      "id": "light",
      "name": "Light",
      "role": "light"
    },
    {
      "id": "dark",
      "name": "Dark",
      "role": "dark",
      "default": true
    }
  ],
  "dataRequirements": [
    {
      "capability": "market.price"
    }
  ]
}
