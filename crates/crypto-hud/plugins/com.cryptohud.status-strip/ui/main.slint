export struct QuoteRow {
    symbol: string,
    price: string,
    change: string,
    positive: bool,
}

component StatusStripFill inherits Path {
    in property <int> tone-index;
    in property <int> edge-kind;

    viewbox-width: 136;
    viewbox-height: 84;
    fit: fill;
    commands: root.edge-kind == 1 ? "M 10 0 L 136 0 L 136 84 L 10 84 Q 0 84 0 74 L 0 10 Q 0 0 10 0 Z"
        : (root.edge-kind == 2 ? "M 0 0 L 126 0 Q 136 0 136 10 L 136 74 Q 136 84 126 84 L 0 84 Z"
        : (root.edge-kind == 3 ? "M 10 0 L 126 0 Q 136 0 136 10 L 136 74 Q 136 84 126 84 L 10 84 Q 0 84 0 74 L 0 10 Q 0 0 10 0 Z"
        : "M 0 0 L 136 0 L 136 84 L 0 84 Z"));
    fill: root.tone-index == 0 ? @linear-gradient(180deg, #1ab5cd 0%, #128bb1 100%)
        : (root.tone-index == 1 ? @linear-gradient(180deg, #29a2d7 0%, #1f6ebc 100%)
        : (root.tone-index == 2 ? @linear-gradient(180deg, #f79d25 0%, #e55e1f 100%)
        : (root.tone-index == 3 ? @linear-gradient(180deg, #dbcc27 0%, #b5aa16 100%)
        : @linear-gradient(180deg, #52b868 0%, #288b52 100%))));
    stroke-width: 0px;
}

export component StatusStrip inherits Window {
    in property <string> widget-id;
    in property <[QuoteRow]> quote-rows;
    in property <string> pairs-heading-text;
    in property <string> source-text;
    in property <string> updated-text;
    in property <string> empty-text;
    in property <bool> rtl-layout: false;
    in property <bool> pin-to-top;
    in property <bool> layout-locked;
    in property <int> widget-width: 618;
    in property <int> widget-height: 92;
    in property <float> widget-scale: 1.0;
    in property <[int]> quote-cell-widths;
    in property <bool> red-up-enabled;
    in property <int> content-opacity;
    in property <string> theme-name: "dark";

    property <int> max-block-count: 5;
    property <int> block-count: root.quote-rows.length <= 0 ? 1 : (root.quote-rows.length > root.max-block-count ? root.max-block-count : root.quote-rows.length);
    property <length> visible-height: 84px;
    property <length> window-padding: 4px;
    property <length> block-width: 122px;
    property <length> card-radius: 10px;
    property <length> upper-highlight-radius: root.card-radius - 1px;
    property <length> top-highlight-radius: root.card-radius - 2px;
    property <length> text-left: 13px;
    property <length> text-horizontal-padding: root.text-left * 2;
    property <length> price-right-gap: 7px;
    property <length> separator-top: 30px;
    property <length> separator-bottom-gap: 37px;
    property <length> lock-button-size: 26px;
    property <length> lock-button-right-gap: 10px;
    property <length> lock-button-top: 8px;
    property <length> lock-button-radius: 7px;
    property <color> default-text-color: #fffffff5;
    property <color> muted-text-color: #ffffffb0;
    property <color> contrast-text-color: #101822eb;
    property <length> block-0-width: root.quote-cell-widths.length > 0 ? root.quote-cell-widths[0] * 1px : root.block-width;
    property <length> block-1-width: root.quote-cell-widths.length > 1 ? root.quote-cell-widths[1] * 1px : root.block-width;
    property <length> block-2-width: root.quote-cell-widths.length > 2 ? root.quote-cell-widths[2] * 1px : root.block-width;
    property <length> block-3-width: root.quote-cell-widths.length > 3 ? root.quote-cell-widths[3] * 1px : root.block-width;
    property <length> block-4-width: root.quote-cell-widths.length > 4 ? root.quote-cell-widths[4] * 1px : root.block-width;
    property <length> block-0-x: 0px;
    property <length> block-1-x: root.block-0-x + root.block-0-width;
    property <length> block-2-x: root.block-1-x + root.block-1-width;
    property <length> block-3-x: root.block-2-x + root.block-2-width;
    property <length> block-4-x: root.block-3-x + root.block-3-width;
    property <length> block-5-x: root.block-4-x + root.block-4-width;
    property <length> canvas-width: root.block-count == 1 ? root.block-1-x
        : (root.block-count == 2 ? root.block-2-x
        : (root.block-count == 3 ? root.block-3-x
        : (root.block-count == 4 ? root.block-4-x : root.block-5-x)));
    property <length> canvas-height: root.visible-height;
    property <length> card-width: root.canvas-width;
    property <length> content-width: root.canvas-width + root.window-padding * 2;
    property <length> content-height: root.canvas-height + root.window-padding * 2;
    property <float> content-scale: root.widget-scale;
    in-out property <bool> card-left-drag-active: false;

    callback drag-move(length, length);
    callback toggle-layout-lock();
    function s(value: length) -> length {
        return value * root.content-scale;
    }
    title: root.widget-id;
    width: root.widget-width * 1px;
    height: root.widget-height * 1px;
    no-frame: true;
    always-on-top: root.pin-to-top;
    background: transparent;

    drag_area := TouchArea {
        width: root.widget-width * 1px;
        height: root.widget-height * 1px;
        mouse-cursor: root.layout-locked ? default : (self.pressed ? grabbing : grab);
        pointer-event(event) => {
            if !root.layout-locked && event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                root.card-left-drag-active = true;
            } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                root.card-left-drag-active = false;
            }
        }
        moved => {
            if !root.layout-locked && root.card-left-drag-active {
                root.drag-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
            }
        }
    }

    canvas := Rectangle {
        x: (root.widget-width * 1px - root.s(root.content-width)) / 2 + root.s(root.window-padding);
        y: (root.widget-height * 1px - root.s(root.content-height)) / 2 + root.s(root.window-padding);
        width: root.s(root.canvas-width);
        height: root.s(root.canvas-height);
        opacity: root.content-opacity / 100;
        clip: true;
        background: transparent;

        card := Rectangle {
            x: 0px;
            y: 0px;
            width: root.s(root.card-width);
            height: root.s(root.visible-height);
            border-radius: root.s(root.card-radius);
            background: transparent;
            border-width: 0px;
            border-color: transparent;
            clip: true;

            for quote[index] in root.quote-rows : Rectangle {
                property <length> cell-x: index == 0 ? root.block-0-x
                    : (index == 1 ? root.block-1-x
                    : (index == 2 ? root.block-2-x
                    : (index == 3 ? root.block-3-x : root.block-4-x)));
                property <length> cell-width: index == 0 ? root.block-0-width
                    : (index == 1 ? root.block-1-width
                    : (index == 2 ? root.block-2-width
                    : (index == 3 ? root.block-3-width : root.block-4-width)));
                x: root.s(self.cell-x);
                y: 0px;
                width: root.s(self.cell-width);
                height: parent.height;
                visible: index < root.max-block-count;
                // Keep a rectangular fill below the decorative path. Some
                // software renderers cull very small scaled paths entirely;
                // the parent card still provides the correct outer clipping.
                background: index == 0 ? @linear-gradient(180deg, #1ab5cd 0%, #128bb1 100%)
                    : (index == 1 ? @linear-gradient(180deg, #29a2d7 0%, #1f6ebc 100%)
                    : (index == 2 ? @linear-gradient(180deg, #f79d25 0%, #e55e1f 100%)
                    : (index == 3 ? @linear-gradient(180deg, #dbcc27 0%, #b5aa16 100%)
                    : @linear-gradient(180deg, #52b868 0%, #288b52 100%))));

                StatusStripFill {
                    tone-index: index;
                    edge-kind: root.block-count == 1 ? 3 : (index == 0 ? 1 : (index + 1 == root.block-count ? 2 : 0));
                    width: parent.width;
                    height: parent.height;
                }
            }

            whole_card_highlight := Rectangle {
                width: parent.width;
                height: parent.height;
                border-radius: root.s(root.card-radius);
                background: @linear-gradient(180deg, #ffffff12 0%, #ffffff0a 18%, #ffffff03 50%, #ffffff00 74%, #00000000 100%);
            }

            upper_gloss := Rectangle {
                x: root.s(1px);
                y: root.s(1px);
                width: parent.width - root.s(2px);
                height: root.s(48px);
                border-radius: root.s(root.upper-highlight-radius);
                background: @linear-gradient(180deg, #ffffff22 0%, #ffffff13 22%, #ffffff06 56%, #ffffff02 82%, #ffffff00 100%);
            }

            top_glint := Rectangle {
                x: root.s(2px);
                y: root.s(2px);
                width: parent.width - root.s(4px);
                height: root.s(12px);
                border-radius: root.s(root.top-highlight-radius);
                background: @linear-gradient(180deg, #ffffff18 0%, #ffffff04 100%);
            }

            bottom_shade := Rectangle {
                width: parent.width;
                height: parent.height;
                border-radius: root.s(root.card-radius);
                background: @linear-gradient(180deg, #00000000 0%, #00000000 42%, #0000000b 78%, #00000016 100%);
            }

            for quote[index] in root.quote-rows : Rectangle {
                property <length> cell-x: index == 0 ? root.block-0-x
                    : (index == 1 ? root.block-1-x
                    : (index == 2 ? root.block-2-x
                    : (index == 3 ? root.block-3-x : root.block-4-x)));
                property <length> cell-width: index == 0 ? root.block-0-width
                    : (index == 1 ? root.block-1-width
                    : (index == 2 ? root.block-2-width
                    : (index == 3 ? root.block-3-width : root.block-4-width)));
                property <bool> contrast-cell: index == 3;
                x: root.s(self.cell-x);
                y: 0px;
                width: root.s(self.cell-width);
                height: parent.height;
                visible: index < root.max-block-count;
                background: transparent;

                Rectangle {
                    x: parent.width - root.s(1px);
                    y: root.s(root.separator-top);
                    width: root.s(1px);
                    height: parent.height - root.s(root.separator-bottom-gap);
                    background: #ffffff28;
                    visible: index + 1 < root.block-count;
                }

                Text {
                    x: root.s(root.text-left);
                    y: root.s(10px);
                    width: parent.width - root.s(root.text-horizontal-padding);
                    height: root.s(16px);
                    text: quote.symbol;
                    color: parent.contrast-cell ? root.contrast-text-color : root.default-text-color;
                    font-size: root.s(11px);
                    font-weight: 700;
                    overflow: elide;
                }

                Text {
                    x: root.s(root.text-left);
                    y: root.s(32px);
                    width: parent.width - root.s(root.text-left + root.price-right-gap);
                    height: root.s(27px);
                    text: quote.price;
                    color: parent.contrast-cell ? root.contrast-text-color : root.default-text-color;
                    font-size: root.s(23px);
                    font-weight: 900;
                    overflow: elide;
                }

                Text {
                    x: root.s(root.text-left);
                    y: root.s(61px);
                    width: parent.width - root.s(root.text-horizontal-padding);
                    height: root.s(16px);
                    text: quote.change;
                    color: parent.contrast-cell ? root.contrast-text-color : root.muted-text-color;
                    font-size: root.s(13px);
                    font-weight: 700;
                    overflow: elide;
                }
            }

            Text {
                x: root.s(root.text-left);
                y: root.s(32px);
                width: parent.width - root.s(root.text-horizontal-padding);
                text: root.empty-text;
                color: root.default-text-color;
                font-size: root.s(18px);
                font-weight: 800;
                horizontal-alignment: root.rtl-layout ? right : left;
                visible: root.quote-rows.length == 0;
                overflow: elide;
            }

        }

        lock_button := Rectangle {
            x: parent.width - root.s(root.lock-button-size) - root.s(root.lock-button-right-gap);
            y: root.s(root.lock-button-top);
            width: root.s(root.lock-button-size);
            height: root.s(root.lock-button-size);
            border-radius: root.s(root.lock-button-radius);
            background: root.layout-locked || lock_touch.has-hover ? #07111dcc : transparent;
            border-width: root.s(1px);
            border-color: root.layout-locked || lock_touch.has-hover ? #ffffff66 : transparent;
            visible: drag_area.has-hover || lock_touch.has-hover;

            Path {
                x: root.s(5px);
                y: root.s(4px);
                width: root.s(16px);
                height: root.s(18px);
                viewbox-width: 24;
                viewbox-height: 24;
                commands: "M 8 4 L 16 4 L 16 6 L 15 6 L 15 12 L 18 14 L 18 16 L 13 16 L 13 21 L 11 21 L 11 16 L 6 16 L 6 14 L 9 12 L 9 6 L 8 6 Z";
                fill: root.layout-locked ? #e2e8f0dc : transparent;
                stroke: #e2e8f0dc;
                stroke-width: root.s(2px);
                stroke-line-cap: round;
                stroke-line-join: round;
            }

            lock_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.toggle-layout-lock(); }
            }
        }
    }
}
