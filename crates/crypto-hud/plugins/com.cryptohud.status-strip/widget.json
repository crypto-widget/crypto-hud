{
  "schemaVersion": 3,
  "id": "com.cryptohud.status-strip",
  "name": "Status Strip",
  "version": "1.0.0",
  "hostApiVersion": ">=0.1.0, <1.0.0",
  "renderer": {
    "kind": "slint",
    "entry": "ui/main.slint",
    "component": "StatusStrip"
  },
  "permissions": {
    "network": false,
    "filesystem": false
  },
  "defaultSize": {
    "width": 618,
    "height": 92
  },
  "sizePolicy": {
    "kind": "symbolGrid",
    "cellSize": {
      "width": 122,
      "height": 84
    },
    "contentPadding": {
      "width": 8,
      "height": 8
    },
    "columns": 5
  },
  "minSymbolLimit": 1,
  "symbolLimit": 5,
  "defaultSymbols": [
    "binance:spot:BTC/USDT",
    "binance:spot:ETH/USDT",
    "binance:spot:SOL/USDT"
  ],
  "previewImages": [
    "ui/preview-light.png"
  ],
  "dataRequirements": [
    {
      "capability": "market.price"
    }
  ]
}
