export struct QuoteRow {
    symbol: string,
    price: string,
    change: string,
    positive: bool,
}

export component OrbitPulse inherits Window {
    in property <string> widget-id;
    in property <[QuoteRow]> quote-rows;
    in property <string> pairs-heading-text;
    in property <string> source-text;
    in property <string> updated-text;
    in property <string> empty-text;
    in property <bool> pin-to-top;
    in property <bool> layout-locked;
    in property <int> widget-width: 480;
    in property <int> widget-height: 480;
    in property <float> widget-scale: 1.0;
    in property <bool> red-up-enabled;
    in property <int> content-opacity;
    in property <string> theme-name: "dark";
    in property <string> chart-line-path;
    in property <string> chart-fill-path;
    in property <bool> chart-ready;
    in property <bool> chart-positive;
    in-out property <bool> card-left-drag-active: false;
    property <bool> light-theme: root.theme-name == "light";
    property <color> lock-hover-background: root.light-theme ? #f8faf0cc : #0f172acc;
    property <color> lock-hover-border: root.light-theme ? #0f8f8277 : #55e6d077;
    property <color> lock-icon-color: root.light-theme ? #0f172acc : #cbd5e1cc;
    property <color> gain-color: root.light-theme ? #16a34a : #50df99;
    property <color> loss-color: root.light-theme ? #dc2626 : #ff6b76;
    property <color> primary-text-color: root.light-theme ? #0f172a : #f8fafc;
    property <color> secondary-text-color: root.light-theme ? #334155 : #cbd5e1cc;
    property <color> chart-color: root.chart-positive
        ? (root.red-up-enabled ? root.loss-color : root.gain-color)
        : (root.red-up-enabled ? root.gain-color : root.loss-color);
    property <color> displayed-change-color: root.quote-rows.length > 0 && root.quote-rows[0].positive
        ? (root.red-up-enabled ? root.loss-color : root.gain-color)
        : (root.red-up-enabled ? root.gain-color : root.loss-color);
    property <color> chart-fill-color: root.light-theme ? #16a34a30 : #14b8a633;
    property <color> chart-glow-color: root.light-theme ? #16a34a50 : #42e6c460;
    property <float> content-scale: root.widget-scale;

    callback drag-move(length, length);
    callback toggle-layout-lock();
    title: root.widget-id;
    width: root.widget-width * 1px;
    height: root.widget-height * 1px;
    no-frame: true;
    always-on-top: root.pin-to-top;
    background: transparent;

    drag_area := TouchArea {
        width: root.widget-width * 1px;
        height: root.widget-height * 1px;
        mouse-cursor: root.layout-locked ? default : (self.pressed ? grabbing : grab);
        pointer-event(event) => {
            if !root.layout-locked && event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                root.card-left-drag-active = true;
            } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                root.card-left-drag-active = false;
            }
        }
        moved => {
            if !root.layout-locked && root.card-left-drag-active {
                root.drag-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
            }
        }
    }

    card := Rectangle {
        x: (root.widget-width * 1px - 480px * root.content-scale) / 2;
        y: (root.widget-height * 1px - 480px * root.content-scale) / 2;
        width: 480px;
        height: 480px;
        transform-origin: { x: 0px, y: 0px };
        transform-scale-x: root.content-scale;
        transform-scale-y: root.content-scale;
        background: transparent;
        opacity: root.content-opacity / 100;

        Image {
            width: parent.width;
            height: parent.height;
            source: @image-url("reference.png");
            image-fit: fill;
            opacity: root.light-theme ? 0.88 : 1;
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: root.light-theme ? #f8faf018 : transparent;
        }

        chart_band := Rectangle {
            x: 98px;
            y: 252px;
            width: 296px;
            height: 88px;
            background: transparent;
            clip: true;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: @radial-gradient(circle 176px at 220px 58px, root.chart-glow-color 0%, #14b8a616 36%, #14b8a600 76%);
                opacity: root.chart-ready ? 0.86 : 0.36;
            }

            Path {
                x: 0px;
                y: 31px;
                width: parent.width;
                height: 42px;
                viewbox-width: 100;
                viewbox-height: 40;
                fit: fill;
                commands: root.chart-fill-path;
                fill: root.chart-fill-color;
                stroke-width: 0px;
                opacity: root.chart-ready ? 0.44 : 0.24;
            }

            Path {
                x: 0px;
                y: 31px;
                width: parent.width;
                height: 42px;
                viewbox-width: 100;
                viewbox-height: 40;
                fit: fill;
                commands: root.chart-line-path;
                fill: transparent;
                stroke: root.chart-glow-color;
                stroke-width: 3.2px;
                stroke-line-cap: round;
                stroke-line-join: round;
                opacity: root.chart-ready ? 0.24 : 0.14;
            }

            Path {
                x: 0px;
                y: 31px;
                width: parent.width;
                height: 42px;
                viewbox-width: 100;
                viewbox-height: 40;
                fit: fill;
                commands: root.chart-line-path;
                fill: transparent;
                stroke: root.chart-color;
                stroke-width: 1.55px;
                stroke-line-cap: round;
                stroke-line-join: round;
                opacity: root.chart-ready ? 1 : 0.45;
            }
        }

        for quote[index] in root.quote-rows : Rectangle {
            visible: index == 0;
            width: parent.width;
            height: parent.height;

            Text {
                x: 128px;
                y: 122px;
                width: 224px;
                text: quote.symbol;
                color: root.primary-text-color;
                font-size: 23px;
                font-weight: 800;
                horizontal-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 236px;
                y: 154px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.chart-color;
                drop-shadow-offset-y: 0px;
                drop-shadow-blur: 8px;
                drop-shadow-color: root.chart-glow-color;
            }

            Text {
                x: 82px;
                y: 174px;
                width: 316px;
                text: quote.price;
                color: root.primary-text-color;
                font-size: 58px;
                font-weight: 900;
                horizontal-alignment: center;
                overflow: elide;
            }

            Text {
                x: 142px;
                y: 248px;
                width: 196px;
                text: quote.change;
                color: root.displayed-change-color;
                font-size: 26px;
                font-weight: 900;
                horizontal-alignment: center;
                overflow: elide;
            }

            Text {
                x: 304px;
                y: 254px;
                width: 32px;
                text: "24h";
                color: root.displayed-change-color;
                font-size: 16px;
                font-weight: 800;
                visible: quote.change != "--";
                overflow: elide;
            }
        }

        Text {
            x: 128px;
            y: 190px;
            width: 224px;
            text: root.empty-text;
            color: root.secondary-text-color;
            font-size: 22px;
            font-weight: 700;
            horizontal-alignment: center;
            visible: root.quote-rows.length == 0;
            overflow: elide;
        }

        Text {
            x: 132px;
            y: 364px;
            width: 216px;
            text: root.source-text;
            color: root.secondary-text-color;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            overflow: elide;
        }

        Text {
            x: 132px;
            y: 388px;
            width: 216px;
            text: root.updated-text;
            color: root.secondary-text-color;
            font-size: 11px;
            horizontal-alignment: center;
            overflow: elide;
        }

        lock_button := Rectangle {
            x: parent.width - 54px;
            y: 52px;
            width: 28px;
            height: 28px;
            border-radius: 14px;
            background: root.layout-locked || lock_touch.has-hover ? root.lock-hover-background : transparent;
            border-width: 1px;
            border-color: root.layout-locked || lock_touch.has-hover ? root.lock-hover-border : transparent;
            visible: drag_area.has-hover || lock_touch.has-hover;

            Path {
                x: 5px;
                y: 4px;
                width: 18px;
                height: 20px;
                viewbox-width: 24;
                viewbox-height: 24;
                commands: "M 8 4 L 16 4 L 16 6 L 15 6 L 15 12 L 18 14 L 18 16 L 13 16 L 13 21 L 11 21 L 11 16 L 6 16 L 6 14 L 9 12 L 9 6 L 8 6 Z";
                fill: root.layout-locked ? root.lock-icon-color : transparent;
                stroke: root.lock-icon-color;
                stroke-width: 2px;
                stroke-line-cap: round;
                stroke-line-join: round;
            }

            lock_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.toggle-layout-lock(); }
            }
        }




    }
}
