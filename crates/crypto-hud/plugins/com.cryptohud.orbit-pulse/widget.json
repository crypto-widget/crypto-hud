{
  "schemaVersion": 3,
  "id": "com.cryptohud.orbit-pulse",
  "name": "Orbit Pulse",
  "version": "1.0.0",
  "hostApiVersion": ">=0.1.0, <1.0.0",
  "renderer": {
    "kind": "slint",
    "entry": "ui/main.slint",
    "component": "OrbitPulse"
  },
  "permissions": {
    "network": false,
    "filesystem": false
  },
  "defaultSize": {
    "width": 480,
    "height": 480
  },
  "minSymbolLimit": 1,
  "symbolLimit": 1,
  "defaultSymbols": [
    "binance:spot:BTC/USDT"
  ],
  "dataRequirements": [
    {
      "capability": "market.price"
    },
    {
      "capability": "market.candles"
    }
  ]
}
