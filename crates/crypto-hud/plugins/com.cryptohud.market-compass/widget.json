{
  "schemaVersion": 3,
  "id": "com.cryptohud.market-compass",
  "name": "Market Compass",
  "version": "1.0.0",
  "hostApiVersion": ">=0.1.0, <1.0.0",
  "renderer": {
    "kind": "slint",
    "entry": "ui/main.slint",
    "component": "MarketCompass"
  },
  "permissions": {
    "network": false,
    "filesystem": false
  },
  "defaultSize": {
    "width": 480,
    "height": 480
  },
  "minSymbolLimit": 1,
  "symbolLimit": 8,
  "defaultSymbols": [
    "binance:spot:BTC/USDT",
    "binance:spot:ETH/USDT",
    "binance:spot:SOL/USDT",
    "binance:spot:BNB/USDT",
    "binance:spot:XRP/USDT",
    "binance:spot:DOGE/USDT",
    "binance:spot:ADA/USDT",
    "binance:spot:DOT/USDT"
  ],
  "previewImages": [
    "ui/preview-light.png",
    "ui/preview-dark.png"
  ],
  "themes": [
    {
      "id": "light",
      "name": "Light",
      "role": "light"
    },
    {
      "id": "dark",
      "name": "Dark",
      "role": "dark",
      "default": true
    }
  ],
  "parameters": [
    {
      "kind": "integer",
      "key": "switch-interval-seconds",
      "name": "Switch interval",
      "nameZhHans": "切换时间",
      "description": "Time between automatic pair switches.",
      "descriptionZhHans": "币种自动切换的时间间隔。",
      "default": 5,
      "minimum": 1,
      "maximum": 60,
      "step": 1,
      "unit": "s",
      "unitZhHans": "秒"
    }
  ],
  "dataRequirements": [
    {
      "capability": "market.price"
    },
    {
      "capability": "market.candles"
    }
  ]
}
